<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'de' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="<%= appBaseUrl %>">
    <title>NSL Portal – Sign In</title>
    <link rel="icon" type="image/png" href="assets/design/favicon_square.png?v=7">
    <link rel="stylesheet" href="css/nsl-design-system.css?v=4">

    <style>
        .login-page-container {
            width: 100%;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .login-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            position: relative;
        }

        .login-form-box {
            background: transparent;
            width: 100%;
            max-width: 500px;
            text-align: center;
        }

        .logo-box {
            margin-bottom: 20px;
        }

        .logo-box img {
            height: 160px;
        }

        h1 {
            font-size: 36px;
            font-weight: 900;
            color: var(--text-main);
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .subtitle {
            font-size: 16px;
            color: var(--text-muted);
            margin-bottom: 30px;
            font-weight: 500;
        }

        .error-msg {
            background: #fff5f5;
            color: var(--nsl-red);
            padding: 12px;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 24px;
            border: 2px solid var(--nsl-red);
            /* Brutalist touch */
        }

        .footer-text-bottom {
            margin-top: 30px;
            font-size: 12px;
            color: #bbb;
            font-weight: 600;
        }

        .btn-submit-brutal {
            width: 100%;
            padding: 16px;
            border-radius: var(--radius-sm);
            font-size: 18px;
            margin-top: 10px;
            font-weight: 800;
            border: 2px solid var(--text-main);
            color: #fff;
            background: var(--text-main);
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.2s ease;
        }

        .btn-submit-brutal:hover {
            box-shadow: 4px 4px 0px var(--nsl-red);
            transform: translate(-2px, -2px);
        }

        /* Specific buttons */
        #btn-student {
            background: var(--text-main);
        }

        #btn-partner {
            background: var(--nsl-red);
            border-color: var(--nsl-red);
        }

        #btn-admin {
            background: var(--nsl-gold);
            border-color: var(--nsl-gold);
            color: var(--text-main);
        }

        #btn-partner:hover {
            box-shadow: 4px 4px 0px var(--text-main);
        }

        #btn-admin:hover {
            box-shadow: 4px 4px 0px var(--text-main);
        }

        @media (max-width: 600px) {
            .login-content {
                padding: 20px 30px;
            }

            .logo-box {
                margin-bottom: 25px;
            }

            .logo-box img {
                height: 120px;
            }

            h1 {
                font-size: 28px;
            }

            .subtitle {
                font-size: 14px;
                margin-bottom: 20px;
            }

            .nsl-tab-btn {
                padding: 10px 15px;
                font-size: 14px;
            }
        }
    </style>
</head>

<body class="bg-pattern">
    <div class="login-page-container">
        <!-- WAVY HEADER: NSL Brand (German Flag) -->
        <div class="wavy-header">
            <svg viewBox="0 0 1000 140" preserveAspectRatio="none" style="width:100%; height:100%;">
                <path d="M0,0 L1000,0 L1000,80 Q500,140 0,140 Z" fill="#f2a900" />
                <path d="M0,0 L1000,0 L1000,140 Q600,140 200,0 Z" fill="#cc1f1f" />
            </svg>
        </div>

        <div class="login-content">
            <div class="login-form-box">
                <div class="logo-box">
                    <img src="assets/design/Logo_Mid_PersonalKampagne.png" alt="NSL" style="object-fit: contain; max-width: 100%;">
                </div>

                <h1>PORTALZUGANG</h1>
                <p class="subtitle">Bitte wählen Sie Ihren Bereich</p>

                <% if (typeof error !=='undefined' && error) { %>
                    <div class="error-msg">
                        <%= error %>
                    </div>
                    <script>
                        alert("<%= error %>");
                    </script>
                    <% } %>

                        <div class="nsl-tabs">
                            <button class="nsl-tab-btn" onclick="switchTab('student')">TALENTE</button>
                            <button class="nsl-tab-btn" onclick="switchTab('partner')">PARTNER</button>
                            <button class="nsl-tab-btn" id="btn-admin" style="display: none;" onclick="switchTab('admin')">Admin</button>
                        </div>

                        <!-- STUDENT FORM -->
                        <div id="tab-student" class="tab-content">
                            <form action="login" method="POST">
                                <input type="hidden" name="_csrf"
                                    value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                <div class="form-group text-left">
                                    <label class="form-label">Talent-ID</label>
                                    <input type="text" name="studentId" class="form-control"
                                        placeholder="z.B. HDEU_Tam_HUYNH_06.01.2004" required>
                                </div>

                                <button type="submit" id="btn-student" class="btn-submit-brutal">LOGIN TALENTE</button>
                            </form>
                        </div>

                        <!-- PARTNER FORM -->
                        <div id="tab-partner" class="tab-content">
                            <form action="partner/login" method="POST">
                                <input type="hidden" name="_csrf"
                                    value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                <div class="form-group text-left">
                                    <label class="form-label">Zugangscode</label>
                                    <input type="password" name="accessCode" class="form-control"
                                        placeholder="Bitte Zugangscode eingeben" required>
                                </div>

                                <button type="submit" id="btn-partner" class="btn-submit-brutal">LOGIN PARTNER</button>
                            </form>
                        </div>

                        <!-- ADMIN FORM -->
                        <div id="tab-admin" class="tab-content">
                            <form action="admin/login" method="POST">
                                <input type="hidden" name="_csrf"
                                    value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                <div class="form-group text-left">
                                    <label class="form-label">Passwort</label>
                                    <input type="password" name="password" class="form-control"
                                        placeholder="Bitte Admin-Passwort eingeben" required>
                                </div>

                                <button type="submit" id="btn-admin-submit" class="btn-submit-brutal">LOGIN ADMIN</button>
                            </form>
                        </div>

                        <div class="footer-text-bottom">
                            &copy; <%= new Date().getFullYear() %> NSL. Alle Rechte vorbehalten.
                        </div>
            </div>
        </div>
    </div>

    <script>
        function switchTab(tabId) {
            // Remove active classes
            document.querySelectorAll('.nsl-tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

            // Add active class to corresponding tab and button
            document.getElementById('tab-' + tabId).classList.add('active');

            // Map tabId to button index
            const index = ['student', 'partner', 'admin'].indexOf(tabId);
            if (index !== -1) {
                document.querySelectorAll('.nsl-tab-btn')[index].classList.add('active');
            }

            // Update URL to reflect current tab (clean URL)
            const basePath = "<%= typeof appBaseUrl !== 'undefined' ? (appBaseUrl.endsWith('/') ? appBaseUrl.slice(0, -1) : appBaseUrl) : '' %>";
            const newPath = basePath + '/' + tabId;
            window.history.replaceState({}, '', newPath);
        }

        // Initialize active tab from server or fallback
        const serverTab = "<%= typeof tab !== 'undefined' ? tab : '' %>";
        const activeTab = serverTab || 'partner';

        switchTab(activeTab);
    </script>
</body>

</html>
