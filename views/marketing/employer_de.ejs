<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NSL Click & Work - Employer Presentation</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #f2a900;
            --nsl-dark: #1a1a1a;
            --nsl-light: #f5f5f5;
        }
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            background: #e0e0e0;
            color: var(--nsl-dark);
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        .page {
            width: 297mm;
            height: 210mm; /* A4 Landscape */
            background: white;
            margin: 20px auto;
            position: relative;
            box-sizing: border-box;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            page-break-after: always;
        }
        @media print {
            body { background: white; margin: 0; }
            .page { margin: 0; box-shadow: none; width: 297mm; height: 210mm; page-break-after: always; }
            @page { size: A4 landscape; margin: 0; }
        }
        
        /* Layout Utils */
        .flex { display: flex; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; height: 100%; }
        .col-left { padding: 40px; background: var(--nsl-dark); color: white; display: flex; flex-direction: column; justify-content: center; }
        .col-right { padding: 40px; display: flex; flex-direction: column; justify-content: center; position: relative; }
        
        .header {
            position: absolute;
            top: 40px; left: 40px; right: 40px;
            display: flex; justify-content: space-between; align-items: flex-start;
            z-index: 10;
        }
        .logo { width: 150px; }
        
        h1 { font-size: 48px; font-weight: 900; margin: 0 0 20px 0; line-height: 1.1; text-transform: uppercase; }
        h2 { font-size: 32px; font-weight: 800; margin: 0 0 15px 0; color: var(--nsl-red); text-transform: uppercase; }
        h3 { font-size: 24px; font-weight: 800; margin: 0 0 10px 0; color: var(--nsl-gold); }
        p { font-size: 18px; line-height: 1.6; margin: 0 0 20px 0; }
        
        .highlight { color: var(--nsl-red); }
        .highlight-gold { color: var(--nsl-gold); }
        
        .screenshot {
            width: 100%;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            border: 4px solid var(--nsl-dark);
            transform: skewY(5deg) rotate(-2deg);
            transition: all 0.3s ease;
        }
        
        .feature-box {
            background: var(--nsl-light);
            border-left: 6px solid var(--nsl-red);
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 0 12px 12px 0;
        }
        .feature-box h4 { margin: 0 0 10px 0; font-size: 20px; font-weight: 800; color: var(--nsl-dark); }
        .feature-box p { font-size: 16px; margin: 0; color: #555; }

        .stat-card {
            background: var(--nsl-dark);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            border-bottom: 6px solid var(--nsl-gold);
        }
        .stat-card .number { font-size: 42px; font-weight: 900; color: var(--nsl-gold); line-height: 1; margin-bottom: 5px; }
        .stat-card .label { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }

        /* Graphics Patterns */
        .bg-pattern {
            position: absolute;
            top: -50%; right: -20%;
            width: 800px; height: 800px;
            background: radial-gradient(circle, rgba(242,169,0,0.1) 0%, rgba(255,255,255,0) 70%);
        }
        .usp-box h3 { margin: 0 0 10px 0; font-size: 22px; color: var(--nsl-gold); }
        .usp-box p { margin: 0; font-size: 16px; line-height: 1.5; color: #ccc; }

        .top-controls {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
            display: flex;
            gap: 15px;
            background: rgba(255,255,255,0.9);
            padding: 10px 15px;
            border-radius: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .lang-switch { display: flex; gap: 5px; }
        .lang-btn {
            text-decoration: none;
            padding: 5px 10px;
            border-radius: 15px;
            color: #666;
            font-weight: bold;
            font-size: 14px;
            transition: all 0.2s;
        }
        .lang-btn.active { background: var(--nsl-dark); color: white; }
        .print-btn {
            background: var(--nsl-red); color: white; border: none; border-radius: 15px;
            padding: 5px 15px; font-weight: bold; font-size: 14px; cursor: pointer;
            display: flex; align-items: center; gap: 5px; transition: all 0.2s;
        }
        .print-btn:hover { background: #a11818; }
        @media print { .top-controls { display: none !important; } }
    </style>
</head>
<body>

    <div class="top-controls">
        <div class="lang-switch">
            <a href="?lang=en" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">EN</a>
            <a href="?lang=de" class="lang-btn <%= lang === 'de' ? 'active' : '' %>">DE</a>
        </div>
        <button onclick="window.print()" class="print-btn">
            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            PDF / Drucken
        </button>
    </div>

    <!-- PAGE 1: Introduction -->
    <div class="page grid-2" style="background: var(--nsl-light);">
        <div class="col-left" style="background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);">
            <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px;">
                <img src="/assets/design/NSL_logo_mid.png" alt="NSL Click & Work" style="height: 60px;">
                <img src="/assets/design/Logo_Mid_PersonalKampagne.png" alt="PersonalKampagne" style="height: 35px;">
            </div>
            <h3 class="highlight-gold">RECRUITMENT DER NÄCHSTEN GENERATION</h3>
            <h1>Talente entdecken.<br>Schneller. Smarter.</h1>
            <p style="color: #ccc; font-size: 20px; max-width: 90%;">Willkommen im NSL Click & Work Portal.<br>Eine revolutionäre Plattform für deutsche Arbeitgeber, um internationale Talente aus 21 europäischen Ländern nahtlos zu entdecken, zu bewerten und einzustellen.</p>
            
            <div style="display: flex; gap: 30px; margin-top: 40px;">
                <div style="background: rgba(255,255,255,0.05); padding: 15px 25px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); border-bottom: 4px solid var(--nsl-gold);">
                    <div style="font-size: 32px; font-weight: 900; color: var(--nsl-gold);">400k+</div>
                    <div style="font-size: 14px; letter-spacing: 1px; color: #aaa; text-transform: uppercase;">Mitarbeiter Netzwerk</div>
                </div>
                <div style="background: rgba(255,255,255,0.05); padding: 15px 25px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); border-bottom: 4px solid var(--nsl-red);">
                    <div style="font-size: 32px; font-weight: 900; color: var(--nsl-red);">100M€</div>
                    <div style="font-size: 14px; letter-spacing: 1px; color: #aaa; text-transform: uppercase;">Umsatzgröße</div>
                </div>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-light); overflow: hidden;">
            <div class="bg-pattern"></div>
            <div style="position: relative; z-index: 1;">
                <img src="/images/marketing/baked/dashboard_full_baked.png" alt="Dashboard Preview" style="width: 145%; margin-left: -30%; margin-top: -15%; margin-bottom: -15%; display: block;">
            </div>
        </div>
    </div>

        <!-- PAGE 2: The Decisive Advantage -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: white;">
        <div class="col-left" style="background: var(--nsl-light); color: var(--nsl-dark); display: flex; align-items: center; justify-content: center;">
            <div style="position: relative; width: 100%; padding: 20px;">
                <img src="/images/marketing/mockup2.png?v=8" class="screenshot" alt="Sharkie AI Search" style="width: 100%; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); border: 2px solid #eee;">
                
                <div style="position: absolute; bottom: -30px; right: -5px; background: var(--nsl-dark); color: white; padding: 20px 30px; border-radius: 50px 0 16px 0; box-shadow: 0 15px 30px rgba(0,0,0,0.3); border-left: 5px solid var(--nsl-gold); max-width: 320px; z-index: 10;">
                    <h4 style="margin: 0 0 10px 0; font-size: 18px; color: var(--nsl-gold);">Sharkie KI-Assistent</h4>
                    <p style="font-size: 14px; margin: 0; color: #ccc;">"Zeige mir Pflegekräfte aus Vietnam mit B1 Deutsch, die im Juli anfangen können."</p>
                </div>
            </div>
        </div>
        <div class="col-right">
            <h3 class="highlight-gold">UNSER ALLEINSTELLUNGSMERKMAL</h3>
            <h2 style="font-size: 40px; line-height: 1.1; margin-bottom: 30px; text-transform: uppercase; color: var(--nsl-red);">Der entscheidende Vorteil.</h2>
            
            <div class="feature-box" style="background: transparent; border-color: var(--nsl-red); padding-left: 0; border: none; border-left: 6px solid var(--nsl-red); padding-left: 20px;">
                <h4 style="font-size: 20px;">🤖 Sharkie KI-Suche</h4>
                <p style="font-size: 16px; line-height: 1.5;">Verschwenden Sie keine Zeit mit Filtern. Sprechen Sie einfach in natürlicher Sprache mit unserer KI, um genau die Kandidaten zu finden, die Sie benötigen. Sharkie versteht Kontext, Berufe und Sprachanforderungen.</p>
            </div>

            <div class="feature-box" style="background: transparent; border-color: var(--nsl-gold); padding-left: 0; border: none; border-left: 6px solid var(--nsl-gold); padding-left: 20px; margin-top: 20px;">
                <h4 style="font-size: 20px;">🎯 Der NSL-Score</h4>
                <p style="font-size: 16px; line-height: 1.5;">Jeder Kandidat durchläuft ein strenges Assessment, das IQ, Entscheidungsfindung und Soft Skills bewertet. Der Richtwert von 48+ garantiert, dass Sie die besten internationalen Talente vor sich haben.</p>
            </div>
        </div>
    </div>

    <!-- PAGE 3: The Process -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: var(--nsl-red);">
        <div class="col-left" style="background: white; color: var(--nsl-dark); padding: 40px; display: flex; flex-direction: column; justify-content: center;">
            <h3 class="highlight-gold">DIE EINSTELLUNGSERFAHRUNG</h3>
            <h2 style="font-size: 40px; line-height: 1.1; margin-bottom: 30px;">Vom Match zur Einstellung.</h2>
            
            <div class="feature-box" style="background: transparent; border-color: var(--nsl-gold); padding-left: 0; border: none; border-left: 6px solid var(--nsl-gold); padding-left: 20px; margin-bottom: 30px;">
                <h4 style="font-size: 20px;">🎥 Transparente Profile &amp; Videos</h4>
                <p style="font-size: 16px; line-height: 1.5;">Überprüfen Sie umfassende Kandidaten-Setcards mit standardisierten Fähigkeiten und sehen Sie sich deren 60-sekündige Einführungsvideos an, um sie persönlich kennenzulernen.</p>
            </div>
            
            <div class="feature-box" style="background: transparent; border-color: #2e7d32; padding-left: 0; border: none; border-left: 6px solid #2e7d32; padding-left: 20px;">
                <h4 style="font-size: 20px;">🛡️ Umfassende Relocation &amp; Visa-Unterstützung</h4>
                <p style="font-size: 16px; line-height: 1.5;">Über das Matching hinaus übernehmen wir die gesamte schwere Arbeit: Dokumentenübersetzung, Berufsanerkennung, Visabearbeitung und kulturelle Integration.</p>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-red); display: flex; flex-direction: column; justify-content: center; align-items: center; overflow: hidden;">
            <div class="bg-pattern"></div>
            <div style="position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; width: 100%;">
                <img src="/images/marketing/baked/setcard_modal_baked.png" alt="Setcard View" style="width: 135%; margin-left: -17%; margin-top: -20%; margin-bottom: calc(-15% - 25px); position: relative; z-index: 1;">
                <img src="/images/marketing/baked/video_frame_baked.png" alt="Video View" style="width: 125%; margin-left: -12%; margin-top: -15%; margin-bottom: -15%; position: relative; z-index: 2;">
            </div>
            <div style="background: white; padding: 15px 30px; border-radius: 50px; font-weight: 800; font-size: 18px; color: var(--nsl-red); box-shadow: 0 10px 20px rgba(0,0,0,0.2); position: relative; z-index: 3; transform: translateY(-5px);">
                Umfassende Setcards
            </div>
        </div>
    </div>

    <!-- PAGE 4: Booking & Call to Action -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: white;">
        <div class="col-left" style="background: white; color: var(--nsl-dark); padding: 60px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start;">
            <h3 class="highlight-gold" style="font-size: 20px; margin-bottom: 20px;">INSTANT BOOKING</h3>
            <h2 style="font-size: 50px; line-height: 1.1; margin-bottom: 30px;">Bereit für die Rekrutierung?</h2>
            <p style="font-size: 20px; color: #444; line-height: 1.5; margin-bottom: 50px;">Erleben Sie unseren <strong>3-Klick Einstellungsprozess</strong>. Durchsuchen Sie Setcards, sehen Sie sich Videos an und buchen Sie Onboarding-Termine sofort mit einem Klick.</p>
            
            <div style="padding-top: 30px; border-top: 2px solid #eee; width: 100%;">
                <p style="margin: 0 0 15px 0; color: #666; font-size: 16px;">Fragen Sie noch heute Ihren NSL-Account-Manager nach Ihrem sicheren Zugangscode.</p>
                <a href="https://www.nsl-personalkampagne.de" target="_blank" style="background: white; color: var(--nsl-dark); padding: 12px 25px; border-radius: 8px; font-weight: bold; font-size: 16px; border: 2px solid #eee; text-decoration: none; display: inline-block; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
                    🌐 Click: www.nsl-personalkampagne.de
                </a>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-light); display: flex; flex-direction: column; justify-content: center; align-items: center; position: relative;">
            <div class="bg-pattern" style="opacity: 0.1; filter: invert(1);"></div>
            <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px; position: absolute; top: 60px;">
                <img src="/assets/design/NSL_logo_mid.png" alt="NSL Click & Work" style="height: 60px;">
                <img src="/assets/design/Logo_Mid_PersonalKampagne.png" alt="PersonalKampagne" style="height: 35px;">
            </div>
            
            <a href="mailto:info@nslclick.com?subject=Partnerschaft%20Anfragen" style="background: var(--nsl-gold); color: var(--nsl-dark); padding: 20px 40px; font-weight: 900; font-size: 26px; display: inline-block; border: 4px solid var(--nsl-dark); text-transform: uppercase; cursor: pointer; text-decoration: none; box-shadow: 12px 12px 0px var(--nsl-dark); position: relative; z-index: 2; transform: rotate(-2deg); transition: all 0.2s ease;">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:8px"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> PARTNERSCHAFT ANFRAGEN
            </a>
        </div>
    </div>
</body>
</html>