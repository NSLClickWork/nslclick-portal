<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NSL Click & Work - Employer Presentation</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #f2a900;
            --nsl-dark: #1a1a1a;
            --nsl-light: #f5f5f5;
        }
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            background: #e0e0e0;
            color: var(--nsl-dark);
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
        .page {
            width: 297mm;
            height: 210mm; /* A4 Landscape */
            background: white;
            margin: 20px auto;
            position: relative;
            box-sizing: border-box;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            page-break-after: always;
        }
        @media print {
            html, body { background: white; margin: 0; padding: 0; width: 100%; height: 100%; }
            .page { margin: 0; padding: 0; box-shadow: none; width: 100%; height: 100%; page-break-after: always; page-break-inside: avoid; border: none; border-radius: 0; }
            @page { size: landscape; margin: 0; }
            .top-controls { display: none !important; }
        }
        
        /* Layout Utils */
        .flex { display: flex; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; height: 100%; }
        .col-left { padding: 40px; background: var(--nsl-dark); color: white; display: flex; flex-direction: column; justify-content: center; }
        .col-right { padding: 40px; display: flex; flex-direction: column; justify-content: center; position: relative; }
        
        .header {
            position: absolute;
            top: 40px; left: 40px; right: 40px;
            display: flex; justify-content: space-between; align-items: flex-start;
            z-index: 10;
        }
        .logo { width: 150px; }
        
        h1 { font-size: 48px; font-weight: 900; margin: 0 0 20px 0; line-height: 1.1; text-transform: uppercase; }
        h2 { font-size: 32px; font-weight: 800; margin: 0 0 15px 0; color: var(--nsl-red); text-transform: uppercase; }
        h3 { font-size: 24px; font-weight: 800; margin: 0 0 10px 0; color: var(--nsl-gold); }
        p { font-size: 18px; line-height: 1.6; margin: 0 0 20px 0; }
        
        .highlight { color: var(--nsl-red); }
        .highlight-gold { color: var(--nsl-gold); }
        
        .screenshot {
            width: 100%;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            border: 4px solid var(--nsl-dark);
            transform: skewY(5deg) rotate(-2deg);
            transition: all 0.3s ease;
        }
        
        .feature-box {
            background: var(--nsl-light);
            border-left: 6px solid var(--nsl-red);
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 0 12px 12px 0;
        }
        .feature-box h4 { margin: 0 0 10px 0; font-size: 20px; font-weight: 800; color: var(--nsl-dark); }
        .feature-box p { font-size: 16px; margin: 0; color: #555; }

        .stat-card {
            background: var(--nsl-dark);
            color: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            border-bottom: 6px solid var(--nsl-gold);
        }
        .stat-card .number { font-size: 42px; font-weight: 900; color: var(--nsl-gold); line-height: 1; margin-bottom: 5px; }
        .stat-card .label { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }

        /* Graphics Patterns */
        .bg-pattern {
            position: absolute;
            top: -50%; right: -20%;
            width: 800px; height: 800px;
            background: radial-gradient(circle, rgba(242,169,0,0.1) 0%, rgba(255,255,255,0) 70%);
        }
        .usp-box h3 { margin: 0 0 10px 0; font-size: 22px; color: var(--nsl-gold); }
        .usp-box p { margin: 0; font-size: 16px; line-height: 1.5; color: #ccc; }

        .top-controls {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
            display: flex;
            gap: 15px;
            background: rgba(255,255,255,0.9);
            padding: 10px 15px;
            border-radius: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .lang-switch { display: flex; gap: 5px; }
        .lang-btn {
            text-decoration: none;
            padding: 5px 10px;
            border-radius: 15px;
            color: #666;
            font-weight: bold;
            font-size: 14px;
            transition: all 0.2s;
        }
        .lang-btn.active { background: var(--nsl-dark); color: white; }
        .print-btn {
            background: var(--nsl-red); color: white; border: none; border-radius: 15px;
            padding: 5px 15px; font-weight: bold; font-size: 14px; cursor: pointer;
            display: flex; align-items: center; gap: 5px; transition: all 0.2s;
        }
        .print-btn:hover { background: #a11818; }
        @media print { .top-controls { display: none !important; } }
    </style>
</head>
<body>

    <div class="top-controls">
        <div class="lang-switch">
            <a href="?lang=en" class="lang-btn <%= lang === 'en' ? 'active' : '' %>">EN</a>
            <a href="?lang=de" class="lang-btn <%= lang === 'de' ? 'active' : '' %>">DE</a>
        </div>
        <button onclick="window.print()" class="print-btn">
            <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            PDF / Print
        </button>
    </div>

    <!-- PAGE 1: Introduction -->
    <div class="page grid-2" style="background: var(--nsl-light);">
        <div class="col-left" style="background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);">
            <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px;">
                <img src="/assets/design/NSL_logo_mid.png" alt="NSL Click & Work" style="height: 60px;">
                <img src="/assets/design/Logo_Mid_PersonalKampagne.png" alt="PersonalKampagne" style="height: 35px;">
            </div>
            <h3 class="highlight-gold">NEXT-GEN RECRUITMENT</h3>
            <h1 style="white-space: nowrap;">Discover Talent.<br>Faster. Smarter.</h1>
            <p style="color: #ccc; font-size: 20px; max-width: 90%;">Welcome to the NSL Click & Work Portal.<br>A revolutionary platform designed for German employers to seamlessly discover, evaluate, and hire international talents across 21 European countries.</p>
            
            <div style="display: flex; gap: 20px; margin-top: 30px;">
                <div class="stat-card">
                    <div class="number">400k+</div>
                    <div class="label">Employees Network</div>
                </div>
                <div class="stat-card" style="border-color: var(--nsl-red);">
                    <div class="number">100M€</div>
                    <div class="label">Revenue Scale</div>
                </div>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-light); overflow: hidden;">
            <div class="bg-pattern"></div>
            <div style="position: relative; z-index: 1;">
                <img src="/images/marketing/baked/dashboard_full_baked.png" alt="Dashboard Preview" style="width: 145%; margin-left: -26%; margin-top: -15%; margin-bottom: -15%; display: block;">
            </div>
        </div>
    </div>

        <!-- PAGE 2: The Decisive Advantage -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: white;">
        <div class="col-left" style="background: var(--nsl-light); color: var(--nsl-dark); display: flex; align-items: center; justify-content: center;">
            <div style="position: relative; width: 100%; padding: 20px;">
                <img src="/images/marketing/mockup2.png?v=8" class="screenshot" alt="Sharkie AI Search" style="width: 100%; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.15); border: 2px solid #eee;">
                
                <div style="position: absolute; bottom: -30px; right: -5px; background: var(--nsl-dark); color: white; padding: 20px 30px; border-radius: 50px 0 16px 0; box-shadow: 0 15px 30px rgba(0,0,0,0.3); border-left: 5px solid var(--nsl-gold); max-width: 320px; z-index: 10;">
                    <h4 style="margin: 0 0 10px 0; font-size: 18px; color: var(--nsl-gold);">Sharkie AI Assistant</h4>
                    <p style="font-size: 14px; margin: 0; color: #ccc;">"Show me nurses from Vietnam with B1 German ready to start in July."</p>
                </div>
            </div>
        </div>
        <div class="col-right">
            <h3 class="highlight-gold">OUR UNIQUE SELLING PROPOSITION</h3>
            <h2 style="font-size: 40px; line-height: 1.1; margin-bottom: 30px; text-transform: uppercase; color: var(--nsl-red);">The Decisive Advantage.</h2>
            
            <div class="feature-box" style="background: transparent; border-color: var(--nsl-red); padding-left: 0; border: none; border-left: 6px solid var(--nsl-red); padding-left: 20px;">
                <h4 style="font-size: 20px; display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg> Sharkie AI Search</h4>
                <p style="font-size: 16px; line-height: 1.5;">Don't waste time clicking filters. Just talk to our AI in natural language to find exactly the candidates you need. Sharkie understands context, professions, and language requirements.</p>
            </div>

            <div class="feature-box" style="background: transparent; border-color: var(--nsl-gold); padding-left: 0; border: none; border-left: 6px solid var(--nsl-gold); padding-left: 20px; margin-top: 20px;">
                <h4 style="font-size: 20px; display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><line x1="12" y1="2" x2="12" y2="4"></line><line x1="12" y1="20" x2="12" y2="22"></line><line x1="2" y1="12" x2="4" y2="12"></line><line x1="20" y1="12" x2="22" y2="12"></line></svg> The NSL-Score</h4>
                <p style="font-size: 16px; line-height: 1.5;">Every candidate undergoes a rigorous assessment evaluating IQ, decision making, and soft skills. The benchmark score of 48+ guarantees you're looking at the top percentile of global talent.</p>
            </div>
        </div>
    </div>

    <!-- PAGE 3: The Process -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: var(--nsl-red);">
        <div class="col-left" style="background: white; color: var(--nsl-dark); padding: 40px; display: flex; flex-direction: column; justify-content: center;">
            <h3 class="highlight-gold">THE HIRING EXPERIENCE</h3>
            <h2 style="font-size: 40px; line-height: 1.1; margin-bottom: 30px;">From Match to Hire.</h2>
            
            <div class="feature-box" style="background: transparent; border-color: var(--nsl-gold); padding-left: 0; border: none; border-left: 6px solid var(--nsl-gold); padding-left: 20px; margin-bottom: 30px;">
                <h4 style="font-size: 20px; display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg> Transparent Profiles &amp; Videos</h4>
                <p style="font-size: 16px; line-height: 1.5;">Review comprehensive candidate Setcards with standardized skills, and watch their 60-second introduction videos to get to know them personally.</p>
            </div>
            
            <div class="feature-box" style="background: transparent; border-color: #2e7d32; padding-left: 0; border: none; border-left: 6px solid #2e7d32; padding-left: 20px;">
                <h4 style="font-size: 20px; display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> Full Relocation &amp; Visa Support</h4>
                <p style="font-size: 16px; line-height: 1.5;">Beyond matching, we handle all the heavy lifting: document translation, professional recognition, visa processing, and cultural integration.</p>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-red); display: flex; flex-direction: column; justify-content: center; align-items: center; overflow: hidden;">
            <div class="bg-pattern"></div>
            <div style="position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; width: 100%;">
                <img src="/images/marketing/baked/setcard_modal_baked.png" alt="Setcard View" style="width: 135%; margin-top: -20%; margin-bottom: calc(-15% - 25px); position: relative; z-index: 1;">
                <img src="/images/marketing/baked/video_frame_baked.png" alt="Video View" style="width: 125%; margin-top: -15%; margin-bottom: -15%; position: relative; z-index: 2;">
            </div>
            <div style="background: white; padding: 15px 30px; border-radius: 50px; font-weight: 800; font-size: 18px; color: var(--nsl-red); box-shadow: 0 10px 20px rgba(0,0,0,0.2); position: relative; z-index: 3; transform: translateY(-5px);">
                Comprehensive Setcards
            </div>
        </div>
    </div>

    <!-- PAGE 4: USP & eSWOT -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: white;">
        <div class="col-left" style="background: var(--nsl-dark); color: white; padding: 40px; display: flex; flex-direction: column; justify-content: center;">
            <h3 class="highlight-gold">OUR UNIQUE SELLING PROPOSITION</h3>
            <h2 style="font-size: 40px; line-height: 1.1; margin-bottom: 30px; text-transform: uppercase;">Why Partner with NSL?</h2>
            
            <div class="usp-box" style="margin-bottom: 25px;">
                <h3 style="display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg> Transparent Direct Recruiting</h3>
                <p>We eliminate middlemen and broker agencies. Our system connects you directly with thoroughly vetted international talents, reducing recruitment costs by up to 40%.</p>
            </div>
            
            <div class="usp-box" style="margin-bottom: 25px;">
                <h3 style="display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> Turnkey Relocation</h3>
                <p>We don't just match; we deliver. From visa applications to professional recognition and finding housing, our dedicated team handles the entire bureaucratic lifecycle.</p>
            </div>

            <div class="usp-box">
                <h3 style="display: flex; align-items: center; gap: 10px;"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg> AI-Powered Matchmaking</h3>
                <p>Our proprietary Sharkie AI goes beyond keywords. It evaluates soft skills, cultural fit, and long-term retention probability, ensuring your hires stay.</p>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-light); color: var(--nsl-dark); display: flex; flex-direction: column; justify-content: center; position: relative;">
            <div class="bg-pattern" style="opacity: 0.5; filter: invert(1);"></div>
            <h3 class="highlight-gold" style="position: relative; z-index: 2;">eSWOT ANALYSIS</h3>
            <h2 style="font-size: 36px; line-height: 1.1; margin-bottom: 30px; text-transform: uppercase; color: var(--nsl-red); position: relative; z-index: 2;">Strategic Overview.</h2>
            
            <div style="position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <!-- Strengths -->
                <div style="background: white; border-top: 5px solid #2e7d32; padding: 20px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <h4 style="margin: 0 0 10px 0; color: #2e7d32; font-size: 18px; text-transform: uppercase;">Strengths</h4>
                    <ul style="margin: 0; padding-left: 20px; font-size: 14px; color: #555;">
                        <li>Largest network of pre-vetted talents</li>
                        <li>Automated, objective screening via AI</li>
                        <li>End-to-end integration support</li>
                    </ul>
                </div>
                <!-- Weaknesses -->
                <div style="background: white; border-top: 5px solid #f2a900; padding: 20px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <h4 style="margin: 0 0 10px 0; color: #f2a900; font-size: 18px; text-transform: uppercase;">Weaknesses</h4>
                    <ul style="margin: 0; padding-left: 20px; font-size: 14px; color: #555;">
                        <li>Dependency on global visa processing times</li>
                        <li>High upfront screening effort</li>
                    </ul>
                </div>
                <!-- Opportunities -->
                <div style="background: white; border-top: 5px solid #1976d2; padding: 20px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <h4 style="margin: 0 0 10px 0; color: #1976d2; font-size: 18px; text-transform: uppercase;">Opportunities</h4>
                    <ul style="margin: 0; padding-left: 20px; font-size: 14px; color: #555;">
                        <li>Expanding to new non-EU talent markets</li>
                        <li>Increasing demand due to demographic shifts</li>
                    </ul>
                </div>
                <!-- Threats -->
                <div style="background: white; border-top: 5px solid #cc1f1f; padding: 20px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                    <h4 style="margin: 0 0 10px 0; color: #cc1f1f; font-size: 18px; text-transform: uppercase;">Threats</h4>
                    <ul style="margin: 0; padding-left: 20px; font-size: 14px; color: #555;">
                        <li>Changing immigration regulations</li>
                        <li>Aggressive competitor poaching</li>
                    </ul>
                </div>
            </div>
            <p style="position: relative; z-index: 2; font-size: 14px; color: #777; margin-top: 25px; font-style: italic;">
                Our strategic position is built on leveraging technology to mitigate external risks while maximizing our core operational strengths.
            </p>
        </div>
    </div>

    <!-- PAGE 5: Booking & Call to Action -->
    <div class="page grid-2" style="grid-template-columns: 1fr 1fr; background: white;">
        <div class="col-left" style="background: white; color: var(--nsl-dark); padding: 60px; display: flex; flex-direction: column; justify-content: center; align-items: flex-start;">
            <h3 class="highlight-gold" style="font-size: 20px; margin-bottom: 20px;">INSTANT BOOKING</h3>
            <h2 style="font-size: 50px; line-height: 1.1; margin-bottom: 30px;">Ready to start hiring?</h2>
            <p style="font-size: 20px; color: #444; line-height: 1.5; margin-bottom: 50px;">Experience our <strong>3-Click Hiring Process</strong>. Browse candidate Setcards, watch their videos, and book onboarding sessions instantly with one click.</p>
            
            <div style="padding-top: 30px; border-top: 2px solid #eee; width: 100%;">
                <p style="margin: 0 0 15px 0; color: #666; font-size: 16px;">Ask your NSL account manager for your secure Access Code today.</p>
                <a href="https://www.nsl-personalkampagne.de" target="_blank" style="background: white; color: var(--nsl-dark); padding: 12px 25px; border-radius: 8px; font-weight: bold; font-size: 16px; border: 2px solid #eee; text-decoration: none; display: inline-block; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:6px"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg> Click: www.nsl-personalkampagne.de
                </a>
            </div>
        </div>
        <div class="col-right" style="background: var(--nsl-light); display: flex; flex-direction: column; justify-content: center; align-items: center; position: relative;">
            <div class="bg-pattern" style="opacity: 0.1; filter: invert(1);"></div>
            <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 40px; position: absolute; top: 60px;">
                <img src="/assets/design/NSL_logo_mid.png" alt="NSL Click & Work" style="height: 60px;">
                <img src="/assets/design/Logo_Mid_PersonalKampagne.png" alt="PersonalKampagne" style="height: 35px;">
            </div>
            
            <a href="mailto:info@nslclick.com?subject=Partnerschaft%20Anfragen" style="background: var(--nsl-gold); color: var(--nsl-dark); padding: 20px 40px; font-weight: 900; font-size: 26px; display: inline-block; border: 4px solid var(--nsl-dark); text-transform: uppercase; cursor: pointer; text-decoration: none; box-shadow: 12px 12px 0px var(--nsl-dark); position: relative; z-index: 2; transform: rotate(-2deg); transition: all 0.2s ease;">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:8px"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> PARTNERSCHAFT ANFRAGEN
            </a>
        </div>
    </div>
</body>
</html>