            </div>
        </div>

        <script>
            async function triggerAIChat(inputId) {
                const inputElement = document.getElementById(inputId);
                const input = inputElement.value;
                if (!input.trim()) return;
                inputElement.value = '';
                
                const resultBox = document.getElementById('aiChatResultBoxAdmin');
                const resultText = document.getElementById('aiChatResultTextAdmin');
                
                resultBox.style.display = 'block';
                resultText.innerHTML = `
                    <style>
                        @keyframes nsl-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
                        .nsl-spinner { width: 20px; height: 20px; border: 3px solid #eee; border-top: 3px solid var(--nsl-red); border-radius: 50%; animation: nsl-spin 1s linear infinite; }
                    </style>
                    <div style="display: flex; align-items: center; gap: 10px; color: var(--nsl-red); font-weight: 700; font-style: italic;">
                        <div class="nsl-spinner"></div>
                        <span>Sharkie is analyzing system data...</span>
                    </div>
                `;
                
                try {
                    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                    const response = await fetch('api/chat', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({ prompt: input, role: 'admin', filteredIds: window.currentFilteredIds || null, _csrf: csrfToken })
                    });
                    
                    const data = await response.json();
                    
                    if (data.response) {
                        let htmlText = data.response.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                        htmlText = htmlText.replace(/\n/g, '<br>');
                        resultText.innerHTML = htmlText;
                    } else if (data.error) {
                        resultText.innerHTML = '<span style="color: red; font-weight: bold;">Error: ' + data.error + '</span>';
                    }
                } catch (error) {
                    console.error("AI Error:", error);
                    resultText.innerHTML = '<span style="color: red; font-weight: bold;">Connection error. Please try again.</span>';
                }
            }
        </script>

