<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <title>NSL Admin - Dashboard</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/nsl-design-system.css">
    <style>
        .table-container { overflow-x: auto; margin-top: 20px; }
        .edit-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; padding: 20px; background: var(--bg-gray); border-radius: var(--radius-sm); margin-top: 10px;}
        
        .status-badge { padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; }
        .status-done { background: #e8f5e9; color: #2e7d32; }
        .status-failed { background: #ffebee; color: #c62828; }
        .status-pending { background: #fff3e0; color: #ef6c00; }

        .job-panel { background: var(--bg-gray); padding: 15px; border-radius: var(--radius-sm); border: 1px solid var(--border-color); margin-top: 20px; display: none; }

        /* Partner Modal Styling */
        .modal-content {
            box-shadow: 8px 8px 0px var(--text-main);
        }
        .prof-tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
        .prof-tag-list label {
            display: inline-block;
            padding: 6px 12px;
            border: 2px solid var(--text-main);
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            background: #fff;
            transition: all 0.2s ease;
        }
        .prof-tag-list label:has(input:checked) {
            background: var(--nsl-red);
            color: white;
            border-color: var(--nsl-red);
        }
        .prof-tag-list input { display: none; }
    </style>
</head>
<body class="bg-pattern">
    <div id="toastContainer" class="toast-container"></div>
    
    <div class="wavy-header">
        <div class="header-controls">
            <button class="header-link" onclick="toggleArchiveView()" id="toggleViewBtn">View Archived</button>
            <a href="/admin/logout" class="header-link">Logout</a>
        </div>
        <svg viewBox="0 0 1000 140" preserveAspectRatio="none" style="width: 100%; height: 100%;">
            <path d="M0,0 L1000,0 L1000,80 Q500,140 0,140 Z" fill="#f2a900" />
            <path d="M0,0 L1000,0 L1000,140 Q600,140 200,0 Z" fill="#cc1f1f" />
        </svg>
    </div>

    <div class="container">
        <img src="/logo.png" alt="NSL" class="nav-brand-logo">
        
        <div class="section-card" style="border: 4px solid var(--text-main); border-radius: 0; box-shadow: 8px 8px 0px var(--text-main);">
            <div class="tabs" style="display: flex; gap: 10px; margin-bottom: 20px;">
                <button class="btn btn-nsl-brutal" id="tabStudents" style="background: var(--text-main); color: #fff;" onclick="switchTab('students')">Students</button>
                <button class="btn btn-nsl-brutal" id="tabPartners" onclick="switchTab('partners')">Partners</button>
            </div>

            <div class="section-title" id="pageTitle" style="color: var(--text-main); border-left: 8px solid var(--nsl-gold); padding-left: 15px;">Active Students</div>
            
            <div id="studentsView">
                <div style="display: flex; gap: 10px; margin-bottom: 20px; align-items: center; flex-wrap: wrap;" id="actionButtons">
                    <button class="btn btn-nsl-brutal" onclick="showAddRow()" style="background: var(--text-main); color: #fff;">+ Add Student</button>
                    <button class="btn btn-nsl-brutal" onclick="batchGenerate('pdfs')" style="border-color: var(--nsl-red); color: var(--nsl-red);">Generate PDF for Selected</button>
                    <button class="btn btn-nsl-brutal" onclick="batchGenerate('videos')" style="border-color: var(--nsl-gold); color: var(--nsl-gold);">Generate Video for Selected</button>
                    <div style="margin-left: auto; display: flex; align-items: center; gap: 10px;">
                        <span id="adminStudentCount" style="font-weight: bold; background: var(--text-main); color: #fff; padding: 5px 12px; border-radius: var(--radius-pill); font-size: 14px;">0</span>
                        <input type="text" id="adminStudentSearch" class="form-control" placeholder="Search students..." style="width: 250px; padding: 8px 15px;" oninput="renderTable()">
                    </div>
                </div>

            <div class="job-panel" id="jobPanel">
                <h4 style="margin-bottom: 10px;">Active Jobs</h4>
                <ul id="jobList" style="font-size: 13px; list-style: none;"></ul>
            </div>

                <div class="table-container" style="max-height: 600px; overflow-y: auto; border: 2px solid var(--text-main);">
                    <table class="nsl-table nsl-sticky-table" style="margin: 0; width: 100%;">
                        <thead>
                            <tr>
                                <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()"></th>
                                <th>Student ID</th>
                                <th>Full Name</th>
                                <th>Profession</th>
                                <th>Center</th>
                                <th>PDF Status</th>
                                <th>Video Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>
            </div>

            <!-- PARTNERS VIEW -->
            <div id="partnersView" style="display: none;">
                <div style="display: flex; gap: 10px; margin-bottom: 20px; align-items: center; flex-wrap: wrap;">
                    <button class="btn btn-nsl-brutal" onclick="showCreatePartnerModal()" style="background: var(--text-main); color: #fff;">+ Generate Partner Code</button>
                    <div style="margin-left: auto; display: flex; align-items: center; gap: 10px;">
                        <span id="adminPartnerCount" style="font-weight: bold; background: var(--text-main); color: #fff; padding: 5px 12px; border-radius: var(--radius-pill); font-size: 14px;">0</span>
                        <input type="text" id="adminPartnerSearch" class="form-control" placeholder="Search partners..." style="width: 250px; padding: 8px 15px;" oninput="renderPartnerTable()">
                    </div>
                </div>
                <div class="table-container" style="max-height: 600px; overflow-y: auto; border: 2px solid var(--text-main);">
                    <table class="nsl-table nsl-sticky-table" style="margin: 0; width: 100%;">
                        <thead>
                            <tr>
                                <th>Partner Name</th>
                                <th>Allowed Professions</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="partnerTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- PARTNER CREATION MODAL -->
    <div id="partnerModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div class="modal-content" style="background: white; padding: 20px; border-radius: var(--radius-sm); border: 4px solid var(--text-main); max-width: 500px; width: 100%;">
            <h3>Generate Partner Code</h3>
            <div id="p-Form">
                <div class="edit-group" style="margin-top: 15px;">
                    <label>Partner Name (Company)</label>
                    <input id="p-Name" class="edit-input" placeholder="e.g. REWE" oninput="updateAutoCode()">
                </div>
                <div class="edit-group" style="margin-top: 15px;">
                    <label>Allowed Professions</label>
                    <div class="prof-tag-list">
                        <label><input type="checkbox" name="prof" value="ALL" onchange="updateAutoCode()"> Tất cả (*)</label>
                        <label><input type="checkbox" name="prof" value="Koch" onchange="updateAutoCode()"> Koch</label>
                        <label><input type="checkbox" name="prof" value="Pflege" onchange="updateAutoCode()"> Pflege</label>
                        <label><input type="checkbox" name="prof" value="ZfA" onchange="updateAutoCode()"> ZfA</label>
                        <label><input type="checkbox" name="prof" value="Mechatroniker" onchange="updateAutoCode()"> Mechatroniker</label>
                        <label><input type="checkbox" name="prof" value="Restaurantfachmann" onchange="updateAutoCode()"> Restaurantfachmann</label>
                        <label><input type="checkbox" name="prof" value="HDEU" onchange="updateAutoCode()"> HDEU</label>
                    </div>
                    <small style="color: #666; font-size: 11px; display: block; margin-top: 8px;">
                        * Hệ thống tự động tìm chuỗi: Nếu chọn <b>Pflege</b>, doanh nghiệp sẽ thấy được cả <b>Pflegefachkraft</b> hay bất kỳ nghề nào có chứa chữ Pflege.
                    </small>
                </div>
                <div class="edit-group" style="margin-top: 15px;">
                    <label>Raw Access Code (You can edit manually)</label>
                    <input id="p-Code" class="edit-input" placeholder="Auto-generated...">
                </div>
                <div style="margin-top: 20px; display: flex; gap: 10px;">
                    <button class="btn btn-nsl-brutal" style="background:var(--nsl-red); color:#fff;" onclick="submitPartner()">Generate & Save</button>
                    <button class="btn btn-nsl-brutal" onclick="document.getElementById('partnerModal').style.display='none'">Cancel</button>
                </div>
            </div>
            <div id="p-Result" style="margin-top: 15px; display: none; padding: 15px; background: #e8f5e9; border: 2px solid #2e7d32; border-radius: 4px;">
                <strong style="color: #2e7d32; font-size: 16px;">Code Generated Successfully!</strong><br><br>
                Please copy this code and send it to the partner. <b style="color: var(--nsl-red);">You won't be able to see it again.</b><br><br>
                <code id="p-ResultCode" style="font-size: 18px; font-weight: bold; background: #fff; border: 2px solid #ccc; padding: 10px; display: block; text-align: center;"></code>
                <button class="btn btn-nsl-brutal" style="margin-top: 15px; width: 100%;" onclick="copyAndClose()">Copy & Close</button>
            </div>
        </div>
    </div>

    <script>
        let allStudents = [];
        let allPartners = [];
        let showingArchived = false;
        let activeJobs = [];
        
        function switchTab(tab) {
            if (tab === 'students') {
                document.getElementById('studentsView').style.display = 'block';
                document.getElementById('partnersView').style.display = 'none';
                document.getElementById('tabStudents').style.background = 'var(--text-main)';
                document.getElementById('tabStudents').style.color = '#fff';
                document.getElementById('tabPartners').style.background = 'transparent';
                document.getElementById('tabPartners').style.color = 'var(--text-main)';
                document.getElementById('pageTitle').innerText = showingArchived ? 'Archived Students' : 'Active Students';
                document.getElementById('toggleViewBtn').style.display = 'inline-block';
            } else {
                document.getElementById('studentsView').style.display = 'none';
                document.getElementById('partnersView').style.display = 'block';
                document.getElementById('tabPartners').style.background = 'var(--text-main)';
                document.getElementById('tabPartners').style.color = '#fff';
                document.getElementById('tabStudents').style.background = 'transparent';
                document.getElementById('tabStudents').style.color = 'var(--text-main)';
                document.getElementById('pageTitle').innerText = 'Partner Management';
                document.getElementById('toggleViewBtn').style.display = 'none';
                fetchPartners();
            }
        }

        // Wrapper for fetch to include CSRF automatically
        async function apiFetch(url, options = {}) {
            const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
            options.headers = options.headers || {};
            options.headers['CSRF-Token'] = csrfToken; // Fallback via Header (tiny-csrf might need body but usually checks headers too)
            
            if (options.body && typeof options.body !== 'string' && !(options.body instanceof FormData)) {
                // If body is JSON object, inject _csrf
                options.body._csrf = csrfToken;
                options.body = JSON.stringify(options.body);
                options.headers['Content-Type'] = 'application/json';
            }
            
            return fetch(url, options);
        }

        function notify(msg, type='success') {
            const c = document.getElementById('toastContainer');
            const t = document.createElement('div');
            t.className = `toast ${type}`;
            t.innerText = msg;
            c.appendChild(t);
            setTimeout(() => t.remove(), 3000);
        }

        async function fetchStudents() {
            const res = await fetch('/admin/students');
            allStudents = await res.json();
            renderTable();
        }

        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return String(unsafe)
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }

        function toggleArchiveView() {
            showingArchived = !showingArchived;
            document.getElementById('toggleViewBtn').innerText = showingArchived ? 'View Active' : 'View Archived';
            document.getElementById('pageTitle').innerText = showingArchived ? 'Archived Students' : 'Active Students';
            document.getElementById('actionButtons').style.display = showingArchived ? 'none' : 'flex';
            renderTable();
        }

        function getStatusBadge(status) {
            if (!status) return '<span class="status-badge">N/A</span>';
            const s = status.toUpperCase();
            if (s.includes('DONE')) return `<span class="status-badge status-done">${s}</span>`;
            if (s.includes('FAIL')) return `<span class="status-badge status-failed">${s}</span>`;
            return `<span class="status-badge status-pending">${s}</span>`;
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            
            const q = (document.getElementById('adminStudentSearch')?.value || '').toLowerCase();
            const filtered = allStudents.filter(s => {
                if (showingArchived ? s.Status !== 'ARCHIVED' : s.Status === 'ARCHIVED') return false;
                if (!q) return true;
                return [s.StudentID, s.FullName, s.ProfessionCode, s.CenterCode].join(' ').toLowerCase().includes(q);
            });
            
            document.getElementById('adminStudentCount').innerText = filtered.length;
            
            filtered.forEach(s => {
                const tr = document.createElement('tr');
                tr.id = `row-${escapeHtml(s.StudentID)}`;
                tr.innerHTML = `
                    <td><input type="checkbox" class="student-cb" value="${escapeHtml(s.StudentID)}"></td>
                    <td><strong>${escapeHtml(s.StudentID)}</strong></td>
                    <td>${escapeHtml(s.FullName)}</td>
                    <td>${escapeHtml(s.ProfessionCode || '')}</td>
                    <td>${escapeHtml(s.CenterCode || '')}</td>
                    <td>${getStatusBadge(escapeHtml(s.SetcardLink ? 'DONE' : s.SetcardStatus || 'PENDING'))}</td>
                    <td>${getStatusBadge(escapeHtml(s.YouTubeLink ? 'DONE' : s.VideoStatus || 'PENDING'))}</td>
                    <td>
                        ${showingArchived 
                            ? `<button class="btn btn-nsl-brutal" style="padding:4px 8px; font-size:11px;" onclick="restoreStudent('${escapeHtml(s.StudentID)}')">Restore</button>`
                            : `<button class="btn btn-nsl-brutal" style="padding:4px 8px; font-size:11px; margin-right: 4px;" onclick="toggleEdit('${escapeHtml(s.StudentID)}')">Edit</button>
                               <button class="btn btn-nsl-brutal" style="padding:4px 8px; font-size:11px; color:#fff; background:var(--nsl-red); border-color:var(--nsl-red);" onclick="archiveStudent('${escapeHtml(s.StudentID)}')">Archive</button>`
                        }
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function toggleSelectAll() {
            const checked = document.getElementById('selectAll').checked;
            document.querySelectorAll('.student-cb').forEach(cb => cb.checked = checked);
        }

        async function batchGenerate(type) {
            const ids = Array.from(document.querySelectorAll('.student-cb:checked')).map(cb => cb.value);
            if (ids.length === 0) return notify('No students selected', 'error');

            try {
                const res = await apiFetch(`/admin/batch/${type}`, {
                    method: 'POST',
                    body: { studentIds: ids }
                });
                const data = await res.json();
                if (res.ok) {
                    notify(`Queued ${ids.length} ${type} jobs`);
                    data.jobs.forEach(j => activeJobs.push(j.jobId));
                    pollJobs();
                } else {
                    notify(data.error || 'Failed to queue', 'error');
                }
            } catch (err) {
                notify('Network error', 'error');
            }
        }

        function toggleEdit(id) {
            const existing = document.querySelector('.edit-row');
            if (existing) existing.remove();
            
            const s = id ? allStudents.find(x => x.StudentID === id) : {};
            const html = `
                <tr class="edit-row">
                    <td colspan="8">
                        <div class="edit-grid">
                            <div class="edit-group"><label>Full Name</label><input id="e-FullName" class="edit-input" value="${escapeHtml(s.FullName)}"></div>
                            <div class="edit-group"><label>Phone</label><input id="e-Phone" class="edit-input" value="${escapeHtml(s.Phone)}"></div>
                            <div class="edit-group"><label>CCCD</label><input id="e-CCCD" class="edit-input" value="${escapeHtml(s.CCCD)}"></div>
                            <div class="edit-group"><label>VoucherCode</label><input id="e-VoucherCode" class="edit-input" value="${escapeHtml(s.VoucherCode)}"></div>
                            <div class="edit-group"><label>ProfessionCode</label><input id="e-ProfessionCode" class="edit-input" value="${escapeHtml(s.ProfessionCode)}"></div>
                            <div class="edit-group"><label>CenterCode</label><input id="e-CenterCode" class="edit-input" value="${escapeHtml(s.CenterCode)}"></div>
                            <div class="edit-group"><label>DeutschLevel</label><input id="e-DeutschLevel" class="edit-input" value="${escapeHtml(s.DeutschLevel)}"></div>
                            <div class="edit-group"><label>AvailableFrom</label><input id="e-AvailableFrom" class="edit-input" value="${escapeHtml(s.AvailableFrom)}"></div>
                            <div class="edit-group"><label>AssessmentScore</label><input id="e-AssessmentScore" class="edit-input" value="${escapeHtml(s.AssessmentScore)}"></div>
                            <div class="edit-group"><label>VideoScore</label><input id="e-VideoScore" class="edit-input" value="${escapeHtml(s.VideoScore)}"></div>
                            <div class="edit-group"><label>Strength1</label><input id="e-Strength1" class="edit-input" value="${escapeHtml(s.Strength1)}"></div>
                            <div class="edit-group"><label>Strength2</label><input id="e-Strength2" class="edit-input" value="${escapeHtml(s.Strength2)}"></div>
                            <div class="edit-group"><label>Strength3</label><input id="e-Strength3" class="edit-input" value="${escapeHtml(s.Strength3)}"></div>
                            <div class="edit-group"><label>PhotoLink (Drive URL)</label><input id="e-PhotoLink" class="edit-input" value="${escapeHtml(s.PhotoLink)}"></div>
                            <div class="edit-group"><label>RawVideoLink (Drive URL)</label><input id="e-RawVideoLink" class="edit-input" value="${escapeHtml(s.RawVideoLink)}"></div>
                        </div>
                        <div style="padding: 10px 20px;">
                            <button class="btn btn-nsl-brutal" style="background:var(--text-main); color:#fff;" onclick="saveEdit('${escapeHtml(id)}')">Save</button>
                            <button class="btn btn-nsl-brutal" onclick="this.closest('tr').remove()">Cancel</button>
                        </div>
                    </td>
                </tr>
            `;

            if (id) {
                document.getElementById(`row-${id}`).insertAdjacentHTML('afterend', html);
            } else {
                document.getElementById('tableBody').insertAdjacentHTML('afterbegin', html);
            }
        }

        function showAddRow() { toggleEdit(null); }

        async function saveEdit(id) {
            const body = {
                FullName: document.getElementById('e-FullName').value,
                Phone: document.getElementById('e-Phone').value,
                CCCD: document.getElementById('e-CCCD').value,
                VoucherCode: document.getElementById('e-VoucherCode').value,
                ProfessionCode: document.getElementById('e-ProfessionCode').value,
                CenterCode: document.getElementById('e-CenterCode').value,
                DeutschLevel: document.getElementById('e-DeutschLevel').value,
                AvailableFrom: document.getElementById('e-AvailableFrom').value,
                AssessmentScore: document.getElementById('e-AssessmentScore').value,
                VideoScore: document.getElementById('e-VideoScore').value,
                Strength1: document.getElementById('e-Strength1').value,
                Strength2: document.getElementById('e-Strength2').value,
                Strength3: document.getElementById('e-Strength3').value,
                PhotoLink: document.getElementById('e-PhotoLink').value,
                RawVideoLink: document.getElementById('e-RawVideoLink').value
            };

            const url = id ? `/admin/students/${id}` : '/admin/students';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await apiFetch(url, { method, body });
                if (res.ok) {
                    notify('Saved successfully');
                    fetchStudents();
                } else {
                    notify('Failed to save', 'error');
                }
            } catch (err) {
                notify('Error saving', 'error');
            }
        }

        async function archiveStudent(id) {
            if (!confirm('Archive this student?')) return;
            const res = await apiFetch(`/admin/students/${id}/archive`, { method: 'PUT', body: {} });
            if (res.ok) { notify('Archived'); fetchStudents(); }
        }

        async function restoreStudent(id) {
            const res = await apiFetch(`/admin/students/${id}/restore`, { method: 'PUT', body: {} });
            if (res.ok) { notify('Restored'); fetchStudents(); }
        }

        async function pollJobs() {
            if (activeJobs.length === 0) {
                document.getElementById('jobPanel').style.display = 'none';
                return;
            }
            document.getElementById('jobPanel').style.display = 'block';
            
            let allDone = true;
            let html = '';

            for (const jid of activeJobs) {
                const res = await fetch(`/admin/jobs/${jid}`);
                const job = await res.json();
                html += `<li><strong>Job ${escapeHtml(jid)} (${escapeHtml(job.type)})</strong>: ${escapeHtml(job.status)} ${job.error ? `<span style="color:red">(${escapeHtml(job.error)})</span>` : ''}</li>`;
                if (job.status !== 'done' && job.status !== 'failed') allDone = false;
            }

            document.getElementById('jobList').innerHTML = html;

            if (!allDone) {
                setTimeout(pollJobs, 3000);
            } else {
                notify('All jobs finished processing');
                activeJobs = [];
                fetchStudents(); // Refresh statuses
            }
        }

        // PARTNER FUNCTIONS
        async function fetchPartners() {
            const res = await fetch('/admin/partners');
            allPartners = await res.json();
            renderPartnerTable();
        }

        function renderPartnerTable() {
            const tbody = document.getElementById('partnerTableBody');
            tbody.innerHTML = '';
            
            const q = (document.getElementById('adminPartnerSearch')?.value || '').toLowerCase();
            const filtered = allPartners.filter(p => {
                if (!q) return true;
                return [p.PartnerName, p.AllowedProfessions, p.Status].join(' ').toLowerCase().includes(q);
            });
            
            document.getElementById('adminPartnerCount').innerText = filtered.length;
            
            filtered.forEach(p => {
                const tr = document.createElement('tr');
                const isRevoked = p.revoked === 'TRUE';
                const statusBadge = isRevoked 
                    ? `<span class="status-badge status-failed">REVOKED</span>` 
                    : `<span class="status-badge status-done">ACTIVE</span>`;
                
                tr.innerHTML = `
                    <td><strong>${escapeHtml(p.partnerName)}</strong></td>
                    <td>${escapeHtml(p.allowedProfessions)}</td>
                    <td>${statusBadge}</td>
                    <td>
                        ${isRevoked 
                            ? `<button class="btn btn-nsl-brutal" style="padding:4px 8px; font-size:11px;" onclick="togglePartnerStatus('${escapeHtml(p.rowIndex)}', false)">Restore</button>`
                            : `<button class="btn btn-nsl-brutal" style="padding:4px 8px; font-size:11px; color:#fff; background:var(--nsl-red); border-color:var(--nsl-red);" onclick="togglePartnerStatus('${escapeHtml(p.rowIndex)}', true)">Revoke</button>`
                        }
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function togglePartnerStatus(rowIndex, revokeStatus) {
            if (revokeStatus && !confirm('Revoke access for this partner?')) return;
            const res = await apiFetch(`/admin/partners/${rowIndex}/revoke`, {
                method: 'PUT',
                body: { revoked: revokeStatus }
            });
            if (res.ok) {
                notify(revokeStatus ? 'Access Revoked' : 'Access Restored');
                fetchPartners();
            } else {
                notify('Error updating status', 'error');
            }
        }

        function showCreatePartnerModal() {
            document.getElementById('p-Form').style.display = 'block';
            document.getElementById('p-Result').style.display = 'none';
            document.getElementById('p-Name').value = '';
            document.querySelectorAll('input[name="prof"]').forEach(cb => cb.checked = false);
            document.getElementById('p-Code').value = '';
            document.getElementById('partnerModal').style.display = 'flex';
        }

        function copyAndClose() {
            const codeText = document.getElementById('p-ResultCode').innerText;
            navigator.clipboard.writeText(codeText).then(() => {
                notify('Copied to clipboard!', 'success');
                document.getElementById('partnerModal').style.display = 'none';
                fetchPartners();
            }).catch(err => {
                console.error('Could not copy text: ', err);
                document.getElementById('partnerModal').style.display = 'none';
                fetchPartners();
            });
        }

        function updateAutoCode() {
            const name = document.getElementById('p-Name').value.trim().toUpperCase().replace(/\s+/g, '_');
            const checkboxes = Array.from(document.querySelectorAll('input[name="prof"]:checked'));
            const profsRaw = checkboxes.map(cb => cb.value);
            const year = new Date().getFullYear();
            
            let profs = profsRaw.join('_');
            if (profsRaw.length === 0 || profsRaw.includes('ALL')) {
                profs = 'ALL';
            }
            
            let autoCode = `Projekt_${name ? name + '_' : ''}${profs}_${year}`;
            document.getElementById('p-Code').value = autoCode;
        }

        async function submitPartner() {
            const partnerName = document.getElementById('p-Name').value.trim();
            const rawCode = document.getElementById('p-Code').value.trim();
            
            const checkboxes = Array.from(document.querySelectorAll('input[name="prof"]:checked'));
            let allowedProfessions = checkboxes.map(cb => cb.value).join(', ');
            if (checkboxes.length === 0 || allowedProfessions.includes('ALL')) {
                allowedProfessions = '*';
            }
            
            if (!partnerName || !rawCode) {
                return notify('Partner Name and Code are required', 'error');
            }
            
            try {
                const res = await apiFetch('/admin/partners', {
                    method: 'POST',
                    body: { partnerName, allowedProfessions, rawCode }
                });
                if (res.ok) {
                    document.getElementById('p-Form').style.display = 'none';
                    document.getElementById('p-ResultCode').innerText = rawCode;
                    document.getElementById('p-Result').style.display = 'block';
                } else {
                    notify('Failed to create partner', 'error');
                }
            } catch (err) {
                notify('Network error', 'error');
            }
        }

        fetchStudents();
    </script>
</body>
</html>
