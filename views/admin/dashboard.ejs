        <div id="aiChatResultBoxAdmin" style="display: none; background: white; border: 3px solid var(--text-main); border-radius: var(--radius-sm); padding: 20px; margin-top: 20px; text-align: left; box-shadow: 6px 6px 0px var(--text-main);">
