<style>
    #chat-widget {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        font-family: 'Inter', sans-serif;
    }
    #chat-bubble {
        width: 60px;
        height: 60px;
        background: var(--nsl-red, #cc1f1f);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: transform 0.2s;
        border: 2px solid #fff;
    }
    #chat-bubble:hover {
        transform: scale(1.1);
    }
    #chat-window {
        display: none;
        width: 350px;
        height: 500px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 2px solid var(--text-main, #333);
        border-radius: 10px;
        box-shadow: 8px 8px 0px var(--text-main, #333);
        flex-direction: column;
        overflow: hidden;
        position: absolute;
        bottom: 80px;
        right: 0;
    }
    #chat-header {
        background: var(--text-main, #333);
        color: white;
        padding: 15px;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    #chat-close {
        cursor: pointer;
        font-size: 20px;
    }
    #chat-body {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 14px;
    }
    .msg { padding: 10px; border-radius: 8px; max-width: 85%; word-wrap: break-word; line-height: 1.4; }
    .msg.bot { background: #f1f1f1; align-self: flex-start; border-bottom-left-radius: 0; color: #333; }
    .msg.bot p { margin: 0 0 8px 0; }
    .msg.bot p:last-child { margin-bottom: 0; }
    .msg.bot ul, .msg.bot ol { margin: 5px 0 10px 0; padding-left: 20px; }
    .msg.bot strong { color: var(--nsl-red, #cc1f1f); font-weight: bold; }
    .msg.bot h1, .msg.bot h2, .msg.bot h3, .msg.bot h4 { margin: 10px 0 5px 0; font-size: 1.1em; color: var(--text-main, #333); }
    .msg.user { background: var(--nsl-gold, #f2a900); color: #fff; align-self: flex-end; border-bottom-right-radius: 0; }
    #chat-footer {
        padding: 10px;
        border-top: 2px solid var(--text-main, #333);
        display: flex;
        gap: 5px;
        background: white;
    }
    #chat-input {
        flex: 1;
        padding: 8px;
        border: 2px solid #ccc;
        border-radius: 4px;
        outline: none;
        font-family: inherit;
    }
    #chat-input:focus {
        border-color: var(--nsl-red, #cc1f1f);
    }
    #chat-send {
        background: var(--nsl-red, #cc1f1f);
        color: white;
        border: 2px solid var(--nsl-red, #cc1f1f);
        padding: 8px 15px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
        font-family: inherit;
    }
    #chat-send:hover {
        background: white;
        color: var(--nsl-red, #cc1f1f);
    }
    .shark-spinner {
        display: inline-block;
        font-size: 24px;
        animation: spin 1s linear infinite;
    }
    @keyframes spin {
        100% { transform: rotate(360deg); }
    }
</style>

<div id="chat-widget">
    <div id="chat-window">
        <div id="chat-header">
            <span>🦈 Sharkie (AI Recruiter)</span>
            <span id="chat-close" onclick="toggleChat()">×</span>
        </div>
        <div id="chat-body">
            <div class="msg bot"><%- __('chat_greeting') %></div>
        </div>
        <div id="chat-footer">
            <input type="text" id="chat-input" placeholder="<%= __('chat_placeholder') %>" onkeypress="if(event.key === 'Enter') sendMsg()">
            <button id="chat-send" onclick="sendMsg()"><%= __('chat_send') %></button>
        </div>
    </div>
    <div id="chat-bubble" onclick="toggleChat()">💬</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
    function toggleChat() {
        const win = document.getElementById('chat-window');
        win.style.display = win.style.display === 'flex' ? 'none' : 'flex';
        if (win.style.display === 'flex') {
            document.getElementById('chat-input').focus();
        }
    }

    async function sendMsg() {
        const input = document.getElementById('chat-input');
        const text = input.value.trim();
        if (!text) return;

        const body = document.getElementById('chat-body');
        
        // Add User Message
        body.innerHTML += `<div class="msg user">${escapeHtmlChat(text)}</div>`;
        input.value = '';
        
        // Add Loading Indicator
        const loadingId = 'loading-' + Date.now();
        body.innerHTML += `
            <div id="${loadingId}" class="msg bot" style="background: transparent; padding: 5px; text-align: center; border: none; box-shadow: none;">
                <div class="shark-spinner">🦈</div>
            </div>`;
        body.scrollTop = body.scrollHeight;

        // Fetch AI Response
        try {
            const csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
            const res = await fetch('/api/chat/message', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'x-csrf-token': csrfToken
                },
                body: JSON.stringify({ message: text, _csrf: csrfToken, filteredIds: window.currentFilteredIds })
            });
            const data = await res.json();
            
            // Remove Loading Indicator
            const loadingEl = document.getElementById(loadingId);
            if (loadingEl) loadingEl.remove();

            // Render Markdown and Add Bot Message
            const htmlReply = marked.parse(data.reply || '...');
            body.innerHTML += `<div class="msg bot">${htmlReply}</div>`;
            body.scrollTop = body.scrollHeight;
        } catch (e) {
            // Remove Loading Indicator
            const loadingEl = document.getElementById(loadingId);
            if (loadingEl) loadingEl.remove();

            body.innerHTML += `<div class="msg bot" style="color:red;"><%= __('chat_error') %></div>`;
            body.scrollTop = body.scrollHeight;
        }
    }
    
    function escapeHtmlChat(unsafe) {
        if (!unsafe) return '';
        return String(unsafe)
             .replace(/&/g, "&amp;")
             .replace(/</g, "&lt;")
             .replace(/>/g, "&gt;")
             .replace(/"/g, "&quot;")
             .replace(/'/g, "&#039;");
    }
</script>
