<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'de' %>">
<head>
    <meta charset="UTF-8">
    <title>Setcard - <%= student.FullName %></title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #f2a900;
            --nsl-navy: #1a3c6e;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Poppins', sans-serif;
            width: 1123px; /* A4 Landscape Width */
            height: 794px; /* A4 Landscape Height */
            background: #ffffff;
            color: #1a1a1a;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* WAVY HEADER */
        .wavy-header {
            position: relative;
            width: 100%;
            height: 80px;
        }
        .wavy-header svg { display: block; width: 100%; height: 100%; }

        /* WAVY FOOTER */
        .wavy-footer {
            width: 100%;
            height: 50px;
            margin-top: auto;
        }
        .wavy-footer svg { display: block; width: 100%; height: 100%; }

        .card-inner {
            flex: 1;
            padding: 5px 60px 0;
            position: relative;
            z-index: 10;
        }

        .card-logo-box { margin-top: 0; margin-bottom: 15px; }
        .card-logo-box img { height: 95px; }

        .profile-flex {
            display: grid;
            grid-template-columns: 280px 560px;
            grid-template-rows: auto 1fr;
            column-gap: 50px;
            row-gap: 0;
            align-items: start;
            justify-content: center;
        }

        .photo-container {
            grid-row: 1 / span 2;
            width: 280px;
            height: 380px;
            border: 6px solid var(--nsl-gold);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            background: #fff;
        }
        .photo-container img { width: 100%; height: 100%; object-fit: cover; }

        .right-column {
            grid-column: 2;
            grid-row: 1 / span 2;
            display: flex;
            flex-direction: column;
            justify-content: center;
            height: 100%;
        }

        .content-area { 
            width: 100%;
        }

        .student-name {
            font-size: 42px;
            font-weight: 900;
            color: var(--nsl-gold);
            text-transform: capitalize;
            margin-bottom: 5px;
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .info-grid {
            display: grid;
            grid-template-columns: auto auto 1fr;
            column-gap: 20px;
            row-gap: 8px;
            font-size: 18px;
            margin-bottom: 20px;
            margin-top: 20px;
        }
        .info-label { font-weight: 800; color: #333; }
        .info-sep { font-weight: 400; color: #555; }
        .info-value { font-weight: 600; color: #444; }

        .sp-section { 
            margin-top: 15px;
        }
        .sp-title {
            font-size: 22px;
            font-weight: 900;
            color: var(--nsl-gold);
            text-transform: uppercase;
            margin-bottom: 8px;
        }
        .sp-yellow-card {
            background: #ffca28;
            border-radius: 12px;
            padding: 15px 25px;
            color: #000;
            font-weight: 700;
            font-size: 16px;
            line-height: 1.4;
            box-shadow: 0 10px 25px rgba(251, 192, 45, 0.12);
        }

        .scores-section {
            margin-top: 40px;
        }

        .score-bar-wrapper {
            margin-bottom: 15px;
            width: 100%;
        }
        .score-label {
            display: flex;
            justify-content: space-between;
            font-weight: 700;
            margin-bottom: 5px;
            font-size: 14px;
        }
        .score-bar-bg {
            background: #eee;
            height: 12px;
            border-radius: 6px;
            overflow: hidden;
        }
        .score-bar-fill {
            background: var(--nsl-red);
            height: 100%;
        }

        .bottom-note {
            font-size: 12px;
            color: #555;
            text-align: center;
            margin-top: 15px;
            line-height: 1.4;
            padding: 0 40px;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="wavy-header">
        <svg viewBox="0 0 1000 110" preserveAspectRatio="none">
            <path d="M0,0 L1000,0 L1000,90 Q500,110 0,90 Z" fill="#f2a900" />
            <path d="M0,0 L1000,0 L1000,60 Q500,90 0,60 Z" fill="#cc1f1f" />
        </svg>
    </div>

    <div class="card-inner">
        <div class="card-logo-box" style="display: flex; justify-content: space-between; align-items: center;">
            <% if (logoBase64) { %>
                <img src="<%= logoBase64 %>" alt="NSL Logo" style="height: 95px;">
            <% } else { %>
                <div style="font-size: 36px; font-weight: 900; color: #111;">NSL</div>
            <% } %>
            <div style="font-size: 38px; font-weight: 900; color: var(--nsl-red); text-transform: uppercase; letter-spacing: 1px;">
                BERUFE - <%= (student.ProfessionCode || 'PFLEGE').toUpperCase() %>
            </div>
        </div>

        <div class="profile-flex">
            <div class="photo-container">
                <% if (photoBase64) { %>
                    <img src="<%= photoBase64 %>" alt="Photo">
                <% } else { %>
                    <div style="width: 100%; height: 100%; background: #ddd; display: flex; align-items: center; justify-content: center; color: #999;">No Photo</div>
                <% } %>
            </div>

            <div class="right-column">
                <div class="content-area">
                    <%
                        function removeAccents(str) {
                            if (!str) return '';
                            return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D');
                        }
                    %>
                    <h1 class="student-name"><%= removeAccents(student.FullName) %></h1>
                    <div class="info-grid">
                        <%
                            let birthYear = 'N/A';
                            const yearMatch = student.StudentID ? student.StudentID.match(/\d{4}$/) : null;
                            if (yearMatch) birthYear = yearMatch[0];
                            
                            function formatValue(val) {
                                if (val === undefined || val === null || val === '' || val === '0' || val === 0 || val === '—' || val === 'Pending') {
                                    return 'Ausstehend';
                                }
                                return val;
                            }
                            
                            let actualScore = student.NSLScore || '0'; 
                        %>
                        <div class="info-label">Geburtsjahr</div><div class="info-sep">:</div><div class="info-value"><%= birthYear %></div>
                        <div class="info-label">Deutsch</div><div class="info-sep">:</div><div class="info-value"><%= formatValue(student.DeutschLevel) %></div>
                        <div class="info-label">NSL-Result</div><div class="info-sep">:</div><div class="info-value"><%= formatValue(actualScore) %></div>
                        <div class="info-label">Leistungs- Integrationslevel</div><div class="info-sep">:</div><div class="info-value"><%= formatValue(student.Rank) %></div>
                        <div class="info-label">Verfügbarkeit</div><div class="info-sep">:</div><div class="info-value"><%= formatValue(student.AvailableFrom) %></div>
                    </div>
                </div>

                <% 
                    let s1 = student.Strength1 || student['Superpower 1'] || student['Strength 1'];
                    let s2 = student.Strength2 || student['Superpower 2'] || student['Strength 2'];
                    let s3 = student.Strength3 || student['Superpower 3'] || student['Strength 3'];
                    let hasSP = s1 || s2 || s3;
                %>
                <% if (hasSP) { %>
                <div class="sp-section">
                    <h3 class="sp-title" style="text-align: center; color: var(--nsl-red);">SUPERPOWERS</h3>
                    <div class="sp-yellow-card" style="text-align: left;">
                        <% if (s1) { %><p style="margin-bottom: 5px;">1. <%= s1 %></p><% } %>
                        <% if (s2) { %><p style="margin-bottom: 5px;">2. <%= s2 %></p><% } %>
                        <% if (s3) { %><p>3. <%= s3 %></p><% } %>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
        
        <% 
            let rawVideo = student['Introduction Video'] || student.YouTubeLink || student.DriveVideoLink || '';
            let hasVideo = rawVideo && rawVideo.trim().length > 5 && rawVideo.toUpperCase() !== 'FALSE';
            let videoLink = hasVideo ? rawVideo.trim() : '#';
        %>
        <% if (hasVideo) { %>
        <div style="text-align: center; margin-top: 15px;">
            <a href="<%= videoLink %>" target="_blank" style="display: inline-block; background: var(--nsl-red); color: white; text-decoration: underline; text-underline-offset: 4px; padding: 14px 40px; border-radius: 50px; font-size: 18px; font-weight: 800;">
                Klicken, um das Video anzusehen
            </a>
        </div>
        <% } %>

        <p class="bottom-note">
            Der NSL-Score basiert auf einer Reihe umfassender Beurteilungen zur Bewertung des IQ, der Entscheidungsfindung und verschiedener anderer Fähigkeiten und erreicht einen durchschnittlichen Benchmarkwert von 48.
        </p>
    </div>

    <div class="wavy-footer">
        <svg viewBox="0 0 1000 100" preserveAspectRatio="none">
            <path d="M0,20 Q500,60 1000,20 L1000,100 L0,100 Z" fill="#000000" />
        </svg>
    </div>
</body>
</html>
