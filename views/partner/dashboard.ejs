<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <base href="<%= appBaseUrl %>">
    <title>NSL Partner Portal</title>
    <link rel="icon" type="image/png" href="logo-shadow.png">
    <link rel="stylesheet" href="css/nsl-design-system.css?v=4">
    <style>
        .nav-brand-logo { height: 100px; margin-top: -5px; margin-bottom: 20px;}
        .lang-switch a { color: #fff; text-decoration: none; margin-left: 10px; font-weight: 600; opacity: 0.7; }
        .lang-switch a.active { color: #fff; opacity: 1; text-decoration: underline; }
        
        .container { padding: 40px; max-width: 1200px; margin: 0 auto; margin-top: -20px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; }
        
        .card-header { padding: 20px; display: flex; align-items: center; border-bottom: 2px solid var(--text-main); background: var(--bg-gray); }
        .avatar { width: 60px; height: 60px; border-radius: 0; object-fit: cover; margin-right: 15px; border: 2px solid var(--text-main); }
        .name { font-size: 18px; font-weight: 800; margin-bottom: 4px; color: var(--text-main); text-transform: uppercase; }
        .profession { font-size: 14px; color: var(--nsl-red); font-weight: 700; text-transform: uppercase; }
        
        .card-body { padding: 20px; font-size: 14px; background: #fff; }
        .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; border-bottom: 1px dashed var(--border-color); padding-bottom: 5px; }
        .info-label { color: var(--text-muted); font-weight: 700; text-transform: uppercase; font-size: 12px; }
        .info-value { font-weight: 800; color: var(--text-main); }
        
        .card-actions { padding: 20px; background: #fff; display: flex; flex-direction: column; gap: 10px; border-top: 2px solid var(--text-main); }
        
        .btn-nsl-brutal {
            padding: 12px;
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            border: 2px solid var(--text-main);
            color: var(--text-main);
            background: transparent;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-nsl-brutal.primary { background: var(--text-main); color: #fff; }
        .btn-nsl-brutal:hover {
            box-shadow: 4px 4px 0px var(--nsl-red);
            transform: translate(-2px, -2px);
        }
    </style>
</head>
<body class="bg-pattern">
    <% 
    function stringToColor(str) {
        if (!str) return 'var(--nsl-red)';
        let hash = 0;
        for (let i = 0; i < str.length; i++) {
            hash = str.charCodeAt(i) + ((hash << 5) - hash);
        }
        let color = '#';
        for (let i = 0; i < 3; i++) {
            let value = (hash >> (i * 8)) & 0xFF;
            value = Math.max(0, Math.min(200, value));
            color += ('00' + value.toString(16)).slice(-2);
        }
        return color;
    }
    function getCenterColor(center) {
        if (!center) return 'var(--nsl-red)';
        const c = center.toUpperCase();
        if (c.startsWith('ANG')) return '#EA4335';  /* Red */
        if (c.startsWith('HDEU')) return '#4285F4'; /* Blue */
        if (c.startsWith('DIE')) return '#8D6E63';  /* Brown */
        if (c.startsWith('LA')) return '#FBBC04';   /* Yellow */
        if (c.startsWith('NW')) return '#34A853';   /* Green */
        return stringToColor(c);
    }
    %>
    <div class="wavy-header">
        <div class="header-controls" style="display: flex; gap: 20px; align-items: center;">
            <div class="lang-switch" style="background: rgba(0,0,0,0.3); padding: 8px 15px; border-radius: 20px;">
                <a href="?lang=de" style="color: #fff; text-decoration: none; font-weight: <%= lang === 'de' ? '900' : '500' %>; opacity: <%= lang === 'de' ? '1' : '0.6' %>;">DE</a> <span style="color:#fff;opacity:0.5">|</span>
                <a href="?lang=en" style="color: #fff; text-decoration: none; font-weight: <%= lang === 'en' ? '900' : '500' %>; opacity: <%= lang === 'en' ? '1' : '0.6' %>;">EN</a> <span style="color:#fff;opacity:0.5">|</span>
                <a href="?lang=vi" style="color: #fff; text-decoration: none; font-weight: <%= lang === 'vi' ? '900' : '500' %>; opacity: <%= lang === 'vi' ? '1' : '0.6' %>;">VI</a>
            </div>
            <a href="partner/logout" class="header-link" style="border: 2px solid #fff; background: transparent; padding: 6px 15px; border-radius: 5px;"><%= __('logout') %></a>
        </div>
        <svg viewBox="0 0 1000 140" preserveAspectRatio="none" style="width: 100%; height: 100%;">
            <path d="M0,0 L1000,0 L1000,80 Q500,140 0,140 Z" fill="#f2a900" />
            <path d="M0,0 L1000,0 L1000,140 Q600,140 200,0 Z" fill="#cc1f1f" />
        </svg>
    </div>

    <div class="container">
        <img src="logo-shadow.png" alt="NSL" class="nav-brand-logo">
        
        <!-- AI Hero Section -->
        <div class="ai-hero-section" style="background: linear-gradient(135deg, #cc1f1f 0%, #f2a900 100%); padding: 40px; border-radius: var(--radius-sm); margin-bottom: 30px; text-align: center; box-shadow: 0 10px 30px rgba(204, 31, 31, 0.2); position: relative; overflow: hidden; border: 4px solid var(--text-main);">
            <div style="position: relative; z-index: 2;">
                <h2 style="color: white; font-size: 28px; font-weight: 900; text-transform: uppercase; margin-bottom: 15px; text-shadow: 2px 2px 0px var(--text-main);">🦈 SHARKIE AI SEARCH</h2>
                <p style="color: white; font-weight: 600; margin-bottom: 25px; font-size: 16px;">Describe the candidate you are looking for, Sharkie will help you filter...</p>
                
                <div style="display: flex; max-width: 700px; margin: 0 auto; background: white; border-radius: 50px; padding: 5px; border: 3px solid var(--text-main); box-shadow: 6px 6px 0px var(--text-main); transition: transform 0.2s;">
                    <input type="text" id="aiSearchInputPartner" placeholder="e.g. Find me a nursing candidate with B1 German..." style="flex: 1; border: none; padding: 15px 25px; font-size: 16px; font-family: 'Montserrat', sans-serif; font-weight: 600; outline: none; border-radius: 40px; color: var(--text-main);">
                    <button onclick="triggerAIChat('aiSearchInputPartner')" style="background: var(--text-main); color: white; border: none; padding: 0 30px; border-radius: 40px; font-weight: 800; font-size: 16px; cursor: pointer; text-transform: uppercase; transition: background 0.2s;">Ask Sharkie</button>
                </div>
            </div>
            <!-- Decorative background elements -->
            <div style="position: absolute; top: -20px; right: -20px; font-size: 100px; opacity: 0.1; transform: rotate(15deg);">✨</div>
            <div style="position: absolute; bottom: -20px; left: -20px; font-size: 100px; opacity: 0.1; transform: rotate(-15deg);">🧠</div>
        </div>

        <div id="aiChatResultBoxPartner" style="display: none; background: white; border: 3px solid var(--text-main); border-radius: var(--radius-sm); padding: 20px; margin-top: 20px; text-align: left; box-shadow: 6px 6px 0px var(--text-main);">
            <div style="font-weight: 900; color: var(--nsl-red); margin-bottom: 10px; text-transform: uppercase;">🦈 Sharkie AI:</div>
            <div id="aiChatResultTextPartner" style="font-size: 15px; line-height: 1.6; color: var(--nsl-dark); margin-bottom: 15px;"></div>
            <div style="font-size: 13px; color: #666; border-top: 1px dashed #ccc; padding-top: 10px; font-weight: 600;">
                Still need help? Contact our human team at <a href="mailto:newsolution.eu@gmail.com" style="color: var(--nsl-red); text-decoration: none;">newsolution.eu@gmail.com</a>
            </div>
        </div>

        <script>
            async function triggerAIChat(inputId) {
                const input = document.getElementById(inputId).value;
                if (!input.trim()) return;
                
                const resultBox = document.getElementById('aiChatResultBoxPartner');
                const resultText = document.getElementById('aiChatResultTextPartner');
                
                resultBox.style.display = 'block';
                resultText.innerHTML = '<span style="color: #666; font-style: italic; font-weight: 600;">Sharkie is searching for candidates...</span>';
                
                try {
                    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                    const response = await fetch('api/chat', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({ prompt: input, role: 'partner', _csrf: csrfToken })
                    });
                    
                    const data = await response.json();
                    
                    if (data.response) {
                        let htmlText = data.response.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                        htmlText = htmlText.replace(/\n/g, '<br>');
                        resultText.innerHTML = htmlText;
                    } else if (data.error) {
                        resultText.innerHTML = '<span style="color: red; font-weight: bold;">Error: ' + data.error + '</span>';
                    }
                } catch (error) {
                    console.error("AI Error:", error);
                    resultText.innerHTML = '<span style="color: red; font-weight: bold;">Connection error. Please try again.</span>';
                }
            }
        </script>

        <div style="margin-bottom: 25px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                <h2 style="color: var(--text-main); font-weight: 900; text-transform: uppercase; border-left: 8px solid var(--nsl-red); padding-left: 15px; margin: 0;">Candidates Database</h2>
            </div>
            
            <div class="tabs" id="rankTabs" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 15px;">
                <button class="btn-nsl-brutal active" style="padding: 8px 15px; background: var(--text-main); color: #fff;" onclick="filterByRank('ALL', this)">ALL</button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('A', this)">Rank A</button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('B', this)">Rank B</button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('C', this)">Rank C</button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('D', this)">Rank D</button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('E', this)">Rank E</button>
            </div>

            <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                <span id="studentCount" style="font-weight: bold; background: var(--text-main); color: #fff; padding: 5px 12px; border-radius: var(--radius-pill); font-size: 14px;"><%= students ? students.length : 0 %> Candidates</span>
                <select id="sortFilter" class="form-control" style="max-width: 170px; padding: 8px 15px; font-size: 14px;" onchange="currentPage=1; filterStudents()">
                    <option value="DEFAULT">Default Sort</option>
                    <option value="SCORE_DESC">Highest Score</option>
                    <option value="NAME_ASC">Name (A-Z)</option>
                    <option value="NAME_DESC">Name (Z-A)</option>
                    <option value="HAS_VIDEO">Has Video Only</option>
                </select>
                <select id="professionFilter" class="form-control" style="max-width: 170px; padding: 8px 15px; font-size: 14px;" onchange="currentPage=1; filterStudents()">
                    <option value="ALL">All Professions</option>
                    <option value="PFLEGE,NURSE,ĐIỀU DƯỠNG,HDEU"><%= __('professions')['pflege'] %></option>
                    <option value="MEC,MECHATRONIKER,MECHANIKER,IT,CƠ KHÍ"><%= __('professions')['mechaniker'] %></option>
                    <option value="KOC,KOCH,ĐẦU BẾP"><%= __('professions')['koch'] %></option>
                    <option value="HOT,HOTEL,RESTAURANT,GASTRONOMIE"><%= __('professions')['hotel'] %></option>
                    <option value="EINZ,EINZELHANDEL,VERKÄUFER,BÄCKEREI,RETAIL,SALES,BÁN HÀNG,BÁN BÁNH"><%= __('professions')['einzelhandel'] %></option>
                </select>
                <input type="text" id="searchInput" class="form-control" placeholder="<%= __('search') %>..." style="flex-grow: 1; max-width: 300px; padding: 8px 15px; font-size: 14px;" onkeyup="currentPage=1; filterStudents()">
            </div>
        </div>
        
        <div class="grid" id="studentsGrid">
            <% if (students && students.length > 0) { %>
                <% students.forEach((student, index) => { 
                    const rank = student.NSLGrade ? student.NSLGrade.toUpperCase() : 'UNKNOWN';
                    const profCode = student.ProfessionCode || 'UNKNOWN';
                    let actualScore = student.NSLScore || student.AssessmentScore || 0;
                    let rawVideo = student['Introduction Video'] || student.YouTubeLink || student.DriveVideoLink || '';
                    let hasVideo = rawVideo && rawVideo.trim().length > 5 && rawVideo.toUpperCase() !== 'FALSE' ? 'true' : 'false';
                    let displayName = student['Short Name'] || student.FullName || '';
                %>
                    <div class="nsl-grid-card" data-index="<%= index %>" data-rank="<%= rank %>" data-prof="<%= profCode %>" data-score="<%= actualScore %>" data-name="<%= displayName.toUpperCase() %>" data-hasvideo="<%= hasVideo %>" style="--card-hover-color: <%= getCenterColor(student.CenterCode) %>;">
                        <div class="card-header">
                            <img src="photos/<%= encodeURIComponent(student.FullName) %>.jpg" onerror="this.onerror=null; this.src='proxy/students/<%= student.StudentID %>/photo'; this.addEventListener('error', function(){this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(student.FullName) %>&background=random'});" alt="Photo" class="avatar">
                            <div>
                                <div class="name"><%= student['Short Name'] || student.FullName %></div>
                                <div class="profession"><%= student.ProfessionCode || '' %></div>
                            </div>
                        </div>
                        <div class="card-body">
                            <% 
                                let birthYear = '—';
                                const yearMatch = student.StudentID ? student.StudentID.match(/\d{4}$/) : null;
                                if (yearMatch) birthYear = yearMatch[0];

                                let displayScore = student.NSLScore || student.AssessmentScore || '—';
                                let actualLevel = student.NSLGrade || '—';
                                let actualAvailability = student.AvailableFrom || '—';
                                let displayDeutschLabel = `${__('deutsch_level')} ${student.DeutschLevel || ''}`;
                            %>
                            <div class="info-row">
                                <span class="info-label"><%= __('birth_year') %></span>
                                <span class="info-value"><%= birthYear %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= displayDeutschLabel %></span>
                                <span class="info-value"><%= student.DeutschLevel || '—' %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= __('nsl_result') %></span>
                                <span class="info-value"><%= displayScore %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= __('integration_level') %></span>
                                <span class="info-value"><%= actualLevel %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= __('availability') %></span>
                                <span class="info-value"><%= actualAvailability %></span>
                            </div>

                            <% if (student.Strength1 || student.Strength2 || student.Strength3) { %>
                            <div style="margin-top: 15px; border-top: 2px solid var(--border-color); padding-top: 10px;">
                                <span class="info-label" style="display:block; margin-bottom:8px;">Superpowers</span>
                                <ul style="list-style-type: square; margin-left: 20px; font-weight: 600; color: var(--text-main); font-size: 13px;">
                                    <% if (student.Strength1) { %><li><%= student.Strength1 %></li><% } %>
                                    <% if (student.Strength2) { %><li><%= student.Strength2 %></li><% } %>
                                    <% if (student.Strength3) { %><li><%= student.Strength3 %></li><% } %>
                                </ul>
                            </div>
                            <% } %>
                        </div>
                        <div class="card-actions">
                            <% if (student.SetcardLink) { %>
                                <a href="<%= student.SetcardLink %>" target="_blank" class="btn-nsl-brutal primary" style="display: block; width: 100%;"><%= __('download_pdf') %></a>
                            <% } %>
                            <% if (student.YouTubeLink || student.DriveVideoLink) { %>
                                <a href="<%= student.YouTubeLink || student.DriveVideoLink %>" target="_blank" class="btn-nsl-brutal" style="display: block; width: 100%;"><%= __('view_video') %></a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No candidates available for your selected criteria.</p>
            <% } %>
        </div>
        <div id="paginationContainer" style="display: flex; justify-content: center; gap: 10px; margin-top: 30px; margin-bottom: 20px; flex-wrap: wrap;"></div>
    </div>
    <script>
        let currentRankFilter = 'ALL';
        let currentPage = 1;
        let itemsPerPage = window.innerWidth <= 768 ? 10 : 20;

        window.addEventListener('resize', () => {
            let newItemsPerPage = window.innerWidth <= 768 ? 10 : 20;
            if (newItemsPerPage !== itemsPerPage) {
                itemsPerPage = newItemsPerPage;
                currentPage = 1;
                filterStudents();
            }
        });

        function changePage(page) {
            currentPage = page;
            filterStudents();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function filterByRank(rank, btn) {
            currentRankFilter = rank;
            currentPage = 1;
            
            // Update active state of buttons
            const buttons = document.getElementById('rankTabs').getElementsByTagName('button');
            for (let i = 0; i < buttons.length; i++) {
                buttons[i].style.background = 'transparent';
                buttons[i].style.color = 'var(--text-main)';
                buttons[i].classList.remove('active');
            }
            btn.style.background = 'var(--text-main)';
            btn.style.color = '#fff';
            btn.classList.add('active');

            filterStudents();
        }

        function filterStudents() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const profFilter = document.getElementById('professionFilter').value.toUpperCase();
            const sortFilter = document.getElementById('sortFilter').value;
            const grid = document.getElementById('studentsGrid');
            if (!grid) return;
            let cards = Array.from(grid.getElementsByClassName('nsl-grid-card'));
            
            let filteredCards = [];
            
            for (let i = 0; i < cards.length; i++) {
                const card = cards[i];
                const text = card.innerText.toLowerCase();
                const cardRank = card.getAttribute('data-rank');
                const cardProf = card.getAttribute('data-prof');
                const cardHasVideo = card.getAttribute('data-hasvideo');
                
                const matchesSearch = text.includes(query);
                const matchesRank = currentRankFilter === 'ALL' || cardRank === currentRankFilter;
                let matchesProf = profFilter === 'ALL';
                if (!matchesProf) {
                    const keywords = profFilter.split(',');
                    matchesProf = keywords.some(kw => cardProf.toUpperCase().includes(kw.trim()));
                }
                const matchesVideo = sortFilter !== 'HAS_VIDEO' || cardHasVideo === 'true';

                if (matchesSearch && matchesRank && matchesProf && matchesVideo) {
                    filteredCards.push(card);
                } else {
                    card.style.display = 'none';
                }
            }
            
            if (sortFilter === 'SCORE_DESC') {
                filteredCards.sort((a, b) => parseFloat(b.getAttribute('data-score') || 0) - parseFloat(a.getAttribute('data-score') || 0));
            } else if (sortFilter === 'NAME_ASC') {
                filteredCards.sort((a, b) => a.getAttribute('data-name').localeCompare(b.getAttribute('data-name')));
            } else if (sortFilter === 'NAME_DESC') {
                filteredCards.sort((a, b) => b.getAttribute('data-name').localeCompare(a.getAttribute('data-name')));
            } else {
                filteredCards.sort((a, b) => parseInt(a.getAttribute('data-index') || 0) - parseInt(b.getAttribute('data-index') || 0));
            }
            
            cards.forEach(card => grid.appendChild(card));
            
            const totalItems = filteredCards.length;
            const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;
            
            if (currentPage > totalPages) {
                currentPage = totalPages;
            }

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            filteredCards.forEach((card, index) => {
                if (index >= startIndex && index < endIndex) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
            
            const countBadge = document.getElementById('studentCount');
            if (countBadge) {
                countBadge.innerText = totalItems + ' Candidates';
            }

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            let container = document.getElementById('paginationContainer');
            if (!container) return;
            container.innerHTML = '';
            
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.className = 'btn-nsl-brutal';
                btn.innerText = i;
                btn.style.padding = '8px 12px';
                if (i === currentPage) {
                    btn.style.background = 'var(--text-main)';
                    btn.style.color = '#fff';
                } else {
                    btn.style.background = 'transparent';
                    btn.style.color = 'var(--text-main)';
                }
                btn.onclick = () => changePage(i);
                container.appendChild(btn);
            }
        }
    </script>
</body>
</html>
