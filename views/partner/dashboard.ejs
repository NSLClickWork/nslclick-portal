<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <base href="<%= appBaseUrl %>">
    <title>NSL Partner Portal</title>
    <link rel="icon" type="image/png" href="assets/design/favicon_square.png?v=10">
    <link rel="stylesheet" href="css/nsl-design-system.css?v=4">
    <style>
        .nav-brand-logo { height: 100px; margin-top: -5px; margin-bottom: 20px;}
        .lang-switch a { color: #fff; text-decoration: none; margin-left: 10px; font-weight: 600; opacity: 0.7; }
        .lang-switch a.active { color: #fff; opacity: 1; text-decoration: underline; }
        
        .container { padding: 40px; max-width: 1200px; margin: 0 auto; margin-top: -20px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; }
        
        .card-header { padding: 20px; display: flex; align-items: center; border-bottom: 2px solid var(--text-main); background: var(--bg-gray); }
        .avatar { width: 60px; height: 60px; border-radius: 0; object-fit: cover; margin-right: 15px; border: 2px solid var(--text-main); }
        .name { font-size: 18px; font-weight: 800; margin-bottom: 4px; color: var(--text-main); text-transform: uppercase; }
        .profession { font-size: 14px; color: var(--nsl-red); font-weight: 700; text-transform: uppercase; }
        
        .card-body { padding: 20px; font-size: 14px; background: #fff; }
        .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; border-bottom: 1px dashed var(--border-color); padding-bottom: 5px; }
        .info-label { color: var(--text-muted); font-weight: 700; text-transform: uppercase; font-size: 12px; }
        .info-value { font-weight: 800; color: var(--text-main); }
        
        .card-actions { padding: 20px; background: #fff; display: flex; flex-direction: column; gap: 10px; border-top: 2px solid var(--text-main); }
        
        .btn-nsl-brutal {
            padding: 12px;
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            border: 2px solid var(--text-main);
            color: var(--text-main);
            background: transparent;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-nsl-brutal.primary { background: var(--text-main); color: #fff; }
        .btn-nsl-brutal:hover {
            box-shadow: 4px 4px 0px var(--nsl-red);
            transform: translate(-2px, -2px);
        }

        /* Mobile Adjustments for AI Search */
        @media (max-width: 768px) {
            .search-bar-wrapper {
                flex-direction: column !important;
                border-radius: 20px !important;
                padding: 10px !important;
                gap: 10px;
            }
            .search-bar-wrapper input {
                border-radius: 15px !important;
                text-align: center;
                padding: 10px !important;
            }
            .search-bar-wrapper button {
                border-radius: 15px !important;
                padding: 12px !important;
                width: 100%;
            }
            .ai-hero-section {
                padding: 20px !important;
            }
        }
        .search-bar-wrapper:focus-within {
            transform: scale(1.02);
            box-shadow: 8px 8px 0px var(--text-main) !important;
        }
        .search-bar-wrapper:hover {
            transform: scale(1.01);
        }
        .ai-search-btn {
            background: var(--text-main);
            color: white;
            border: none;
            padding: 15px 35px;
            border-radius: 40px;
            font-weight: 900;
            font-size: 16px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .ai-search-btn:hover {
            background: var(--nsl-red);
            transform: scale(1.05);
        }
        .ai-search-btn:active {
            transform: scale(0.95);
        }
    </style>
</head>
<body class="bg-pattern">
    <% 
    function stringToColor(str) {
        if (!str) return 'var(--nsl-red)';
        let hash = 0;
        for (let i = 0; i < str.length; i++) {
            hash = str.charCodeAt(i) + ((hash << 5) - hash);
        }
        let color = '#';
        for (let i = 0; i < 3; i++) {
            let value = (hash >> (i * 8)) & 0xFF;
            value = Math.max(0, Math.min(200, value));
            color += ('00' + value.toString(16)).slice(-2);
        }
        return color;
    }
    function getCenterColor(center) {
        if (!center) return 'var(--nsl-red)';
        const c = center.toUpperCase();
        if (c.startsWith('ANG')) return '#EA4335';  /* Red */
        if (c.startsWith('HDEU')) return '#4285F4'; /* Blue */
        if (c.startsWith('DIE')) return '#8D6E63';  /* Brown */
        if (c.startsWith('LA')) return '#FBBC04';   /* Yellow */
        if (c.startsWith('NW')) return '#34A853';   /* Green */
        return stringToColor(c);
    }
    %>
    <div class="wavy-header">
        <div class="header-logo" style="position: absolute; top: 50px; left: 30px; z-index: 100;">
            <img src="assets/design/NSL_logo_mid.png" alt="NSL Logo" style="height: 50px;">
        </div>
        <div class="header-controls" style="display: flex; gap: 20px; align-items: center;">
            <div class="lang-switch" style="background: rgba(0,0,0,0.3); padding: 8px 15px; border-radius: 20px; display: flex; align-items: center; gap: 10px;">
                <a href="javascript:void(0)" onclick="window.location.search='?lang=de&_cb=<%= Date.now() %>'" style="color: #fff; text-decoration: none; font-weight: <%= typeof lang !== 'undefined' && lang === 'de' ? '900' : '500' %>; opacity: <%= typeof lang !== 'undefined' && lang === 'de' ? '1' : '0.6' %>;">DE</a>
                <span style="color:#fff;opacity:0.5">|</span>
                <a href="javascript:void(0)" onclick="window.location.search='?lang=en&_cb=<%= Date.now() %>'" style="color: #fff; text-decoration: none; font-weight: <%= typeof lang !== 'undefined' && lang === 'en' ? '900' : '500' %>; opacity: <%= typeof lang !== 'undefined' && lang === 'en' ? '1' : '0.6' %>;">EN</a>
                <span style="color:#fff;opacity:0.5">|</span>
                <a href="javascript:void(0)" onclick="window.location.search='?lang=vi&_cb=<%= Date.now() %>'" style="color: #fff; text-decoration: none; font-weight: <%= typeof lang !== 'undefined' && lang === 'vi' ? '900' : '500' %>; opacity: <%= typeof lang !== 'undefined' && lang === 'vi' ? '1' : '0.6' %>;">VI</a>
            </div>
            <a href="partner/logout" class="header-link" style="border: 2px solid #fff; background: transparent; padding: 6px 15px; border-radius: 5px;"><%= __('logout') %></a>
        </div>
        <svg viewBox="0 0 1000 140" preserveAspectRatio="none" style="width: 100%; height: 100%;">
            <path d="M0,0 L1000,0 L1000,80 Q500,140 0,140 Z" fill="#f2a900" />
            <path d="M0,0 L1000,0 L1000,140 Q600,140 200,0 Z" fill="#cc1f1f" />
        </svg>
    </div>

    <div class="container">
        <img src="assets/design/Logo_Mid_PersonalKampagne.png" alt="NSL" class="nav-brand-logo">
        
        <!-- AI Hero Section -->
        <div class="ai-hero-section" style="background: linear-gradient(135deg, #cc1f1f 0%, #f2a900 100%); padding: 40px; border-radius: var(--radius-sm); margin-bottom: 30px; text-align: center; box-shadow: 0 10px 30px rgba(204, 31, 31, 0.2); position: relative; overflow: hidden; border: 4px solid var(--text-main);">
            <div style="position: relative; z-index: 2;">
                <h2 style="color: white; font-size: 28px; font-weight: 900; text-transform: uppercase; margin-bottom: 15px; text-shadow: 2px 2px 0px var(--text-main);">🦈 <%= __('sharkie_ai_search') %></h2>
                <p style="color: white; font-weight: 600; margin-bottom: 25px; font-size: 16px;"><%= __('sharkie_desc') %></p>
                
                <div class="search-bar-wrapper" style="display: flex; align-items: center; max-width: 700px; margin: 0 auto; background: white; border-radius: 50px; padding: 8px; border: 3px solid var(--text-main); box-shadow: 6px 6px 0px var(--text-main); transition: transform 0.2s;">
                    <input type="text" id="aiSearchInputPartner" placeholder="<%= __('sharkie_placeholder') %>" onkeypress="if(event.key === 'Enter') triggerAIChat('aiSearchInputPartner')" style="flex: 1; border: none; padding: 15px 25px; font-size: 16px; font-family: 'Inter', sans-serif; font-weight: 600; outline: none; border-radius: 40px; color: var(--text-main); min-width: 0;">
                    <button onclick="triggerAIChat('aiSearchInputPartner')" class="ai-search-btn"><%= __('ask_sharkie') %></button>
                </div>
            </div>
            <!-- Decorative background elements -->
            <div style="position: absolute; top: -20px; right: -20px; font-size: 100px; opacity: 0.1; transform: rotate(15deg);">✨</div>
            <div style="position: absolute; bottom: -20px; left: -20px; font-size: 100px; opacity: 0.1; transform: rotate(-15deg);">🧠</div>
        </div>

        <div id="aiChatResultBoxPartner" style="display: none; background: white; border: 3px solid var(--text-main); border-radius: var(--radius-sm); padding: 20px; margin-top: 20px; margin-bottom: 30px; text-align: left; box-shadow: 6px 6px 0px var(--text-main);">
            <div style="font-weight: 900; color: var(--nsl-red); margin-bottom: 10px; text-transform: uppercase;">🦈 Sharkie AI:</div>
            <div id="aiChatResultTextPartner" style="font-size: 15px; line-height: 1.6; color: var(--nsl-dark); margin-bottom: 15px;"></div>
            <div style="font-size: 13px; color: #666; border-top: 1px dashed #ccc; padding-top: 10px; font-weight: 600;">
                Still need help? Contact our human team at <a href="mailto:newsolution.eu@gmail.com" style="color: var(--nsl-red); text-decoration: none;">newsolution.eu@gmail.com</a>
            </div>
        </div>

        <script>
            async function triggerAIChat(inputId) {
                const inputElement = document.getElementById(inputId);
                const input = inputElement.value;
                if (!input.trim()) return;
                inputElement.value = '';
                
                const resultBox = document.getElementById('aiChatResultBoxPartner');
                const resultText = document.getElementById('aiChatResultTextPartner');
                
                resultBox.style.display = 'block';
                resultText.innerHTML = `
                    <style>
                        @keyframes spin { 100% { transform: rotate(360deg); } }
                        .shark-spinner { display: inline-block; font-size: 24px; animation: spin 1s linear infinite; }
                    </style>
                    <div style="display: flex; align-items: center; gap: 10px; color: var(--nsl-red); font-weight: 700; font-style: italic;">
                        <div class="shark-spinner">🦈</div>
                        <span><%= __('sharkie_searching') %></span>
                    </div>
                `;
                
                try {
                    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                    const response = await fetch('api/chat', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'x-csrf-token': csrfToken
                        },
                        body: JSON.stringify({ prompt: input, role: 'partner', filteredIds: window.currentFilteredIds || null, _csrf: csrfToken })
                    });
                    
                    const data = await response.json();
                    
                    if (data.response) {
                        let htmlText = data.response.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                        htmlText = htmlText.replace(/\n/g, '<br>');
                        resultText.innerHTML = htmlText;
                    } else if (data.error) {
                        resultText.innerHTML = '<span style="color: red; font-weight: bold;">Error: ' + data.error + '</span>';
                    }
                } catch (error) {
                    console.error("AI Error:", error);
                    resultText.innerHTML = '<span style="color: red; font-weight: bold;">Connection error. Please try again.</span>';
                }
            }
        </script>

        <div style="margin-bottom: 25px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 15px;">
                <h2 style="color: var(--text-main); font-weight: 900; text-transform: uppercase; border-left: 8px solid var(--nsl-red); padding-left: 15px; margin: 0;"><%= __('candidates_database') %></h2>
                <a href="<%= partnerBookingLink %>" target="_blank" class="btn-nsl-brutal" style="background: var(--nsl-gold); color: var(--text-main); text-decoration: none; display: flex; align-items: center; padding: 10px 15px;">
                    <span style="font-size: 1.2em; margin-right: 8px;">🤝</span>
                    <%= __('req_partner_onboarding') %>
                </a>
            </div>
            
            <div class="tabs" id="rankTabs" style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 15px;">
                <button class="btn-nsl-brutal active" style="padding: 8px 15px; background: var(--text-main); color: #fff;" onclick="filterByRank('ALL', this)"><%= __('rank_all') %></button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('A', this)"><%= __('rank_a') %></button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('B', this)"><%= __('rank_b') %></button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('C', this)"><%= __('rank_c') %></button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('D', this)"><%= __('rank_d') %></button>
                <button class="btn-nsl-brutal" style="padding: 8px 15px;" onclick="filterByRank('E', this)"><%= __('rank_e') %></button>
            </div>

            <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                <span id="studentCount" style="font-weight: bold; background: var(--text-main); color: #fff; padding: 5px 12px; border-radius: var(--radius-pill); font-size: 14px;"><%= students ? students.length : 0 %> <%= __('candidates_count') %></span>
                <button id="fullInfoToggle" class="btn-nsl-brutal" style="padding: 6px 12px; font-size: 13px; display: flex; align-items: center; gap: 8px; background: var(--text-main); color: #fff;" onclick="toggleFullInfo(this)">
                    <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: #0f0; border: 2px solid #fff;" id="fullInfoIndicator"></span>
                    <%= __('full_info_only') %>
                </button>
                <select id="sortFilter" class="form-control" style="max-width: 220px; padding: 8px 15px; font-size: 14px;" onchange="currentPage=1; filterStudents()">
                    <option value="DEFAULT"><%= __('sort_default') %></option>
                    <option value="SCORE_DESC"><%= __('sort_highest_score') %></option>
                    <option value="NAME_ASC"><%= __('sort_name_asc') %></option>
                    <option value="NAME_DESC"><%= __('sort_name_desc') %></option>
                    <option value="HAS_VIDEO"><%= __('sort_has_video') %></option>
                </select>
                <% if (typeof partner !== 'undefined' && partner && partner.allowedProfessions === 'ALL') { %>
                <select id="professionFilter" class="form-control" style="max-width: 250px; padding: 8px 15px; font-size: 14px;" onchange="currentPage=1; filterStudents()">
                    <option value="ALL"><%= __('all_professions') %></option>
                    <option value="PFLEGE,NURSE,ĐIỀU DƯỠNG,HDEU"><%= __('pflege', 'professions') %></option>
                    <option value="MEC,MECHATRONIKER,MECHANIKER,IT,CƠ KHÍ"><%= __('mechaniker', 'professions') %></option>
                    <option value="KOC,KOCH,ĐẦU BẾP"><%= __('koch', 'professions') %></option>
                    <option value="HOT,HOTEL,RESTAURANT,GASTRONOMIE"><%= __('hotel', 'professions') %></option>
                    <option value="EINZ,EINZELHANDEL,VERKÄUFER,BÄCKEREI,RETAIL,SALES,BÁN HÀNG,BÁN BÁNH"><%= __('einzelhandel', 'professions') %></option>
                </select>
                <% } else { %>
                <input type="hidden" id="professionFilter" value="ALL">
                <% } %>
                <input type="text" id="searchInput" class="form-control" placeholder="<%= __('search') %>..." style="flex-grow: 1; max-width: 300px; padding: 8px 15px; font-size: 14px;" onkeyup="currentPage=1; filterStudents()">
            </div>
        </div>
        
        <div class="grid" id="studentsGrid">
            <% if (students && students.length > 0) { %>
                <% students.forEach((student, index) => { 
                    const rank = student.NSLGrade ? student.NSLGrade.toUpperCase() : 'UNKNOWN';
                    const profCode = student.ProfessionCode || 'UNKNOWN';
                    let actualScore = student.NSLScore || student.AssessmentScore || 0;
                    let rawVideo = student['Introduction Video'] || student.YouTubeLink || student.DriveVideoLink || '';
                    let hasVideo = rawVideo && rawVideo.trim().length > 5 && rawVideo.toUpperCase() !== 'FALSE' ? 'true' : 'false';
                    let hasPhoto = student.PhotoLink && student.PhotoLink.trim() !== '' ? 'true' : 'false';
                    let displayName = student['Short Name'] || student.FullName || '';
                %>
                    <div class="nsl-grid-card" data-studentid="<%= student.StudentID %>" data-index="<%= index %>" data-rank="<%= rank %>" data-prof="<%= profCode %>" data-score="<%= actualScore %>" data-name="<%= displayName.toUpperCase() %>" data-hasvideo="<%= hasVideo %>" data-hasphoto="<%= hasPhoto %>" style="--card-hover-color: <%= getCenterColor(student.CenterCode) %>; position: relative;">
                        <% if (student.ProgressStatus && parseInt(student.ProgressStatus) >= 4) { %>
                            <div style="position: absolute; top: 4px; right: 4px; z-index: 10; width: 110px; height: 50px; filter: drop-shadow(2px 2px 0px #333); transform-origin: 102px 4px; transform: rotate(-2deg);">
                                <svg width="110" height="50" viewBox="0 0 110 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="position: absolute; top: 0; left: 0;">
                                    <!-- Tag Body -->
                                    <path d="M4 24H96L106 35L96 46H4C1.79086 46 0 44.2091 0 42V28C0 25.79086 1.79086 24 4 24Z" fill="#cc1f1f" stroke="#333" stroke-width="2"/>
                                    <!-- Hole -->
                                    <circle cx="92" cy="35" r="3" fill="#f5f5f5" stroke="#333" stroke-width="2"/>
                                    <!-- String -->
                                    <path d="M 102 4 C 105 15, 95 25, 92 35" stroke="#333" stroke-width="1.5" fill="none" />
                                    <!-- Pin -->
                                    <circle cx="102" cy="4" r="3.5" fill="#ffdd00" stroke="#333" stroke-width="1.5"/>
                                    <circle cx="101" cy="3" r="1" fill="#fff" opacity="0.8"/>
                                </svg>
                                <span style="position: absolute; top: 29.5px; left: 8px; color: white; font-weight: 800; font-size: 10px; letter-spacing: 0.5px;">AUSGEWÄHLT</span>
                            </div>
                        <% } %>
                        <div class="card-header" style="position: relative;">
                            <img src="photos/<%= encodeURIComponent(student.FullName) %>.jpg" onerror="this.onerror=null; this.src='proxy/students/<%= student.StudentID %>/photo'; this.addEventListener('error', function(){this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(student.FullName) %>&background=random'});" alt="Photo" class="avatar">
                            <div style="flex: 1; min-width: 0; <%= (student.ProgressStatus && parseInt(student.ProgressStatus) >= 4) ? 'padding-right: 90px;' : '' %>">
                                <div class="name" style="word-wrap: break-word;"><%= student['Short Name'] || student.FullName %></div>
                                <div class="profession" style="word-wrap: break-word;"><%= student.ProfessionCode || '' %></div>
                            </div>
                        </div>
                        <div class="card-body">
                            <% 
                                let birthYear = '—';
                                const yearMatch = student.StudentID ? student.StudentID.match(/\d{4}$/) : null;
                                if (yearMatch) birthYear = yearMatch[0];

                                let displayScore = student.NSLScore || student.AssessmentScore || '—';
                                let actualLevel = student.NSLGrade || '—';
                                let actualAvailability = student.AvailableFrom || '—';
                                let displayDeutschLabel = `${__('deutsch_level')} ${student.DeutschLevel || ''}`;
                            %>
                            <div class="info-row">
                                <span class="info-label"><%= __('birth_year') %></span>
                                <span class="info-value"><%= birthYear %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= displayDeutschLabel %></span>
                                <span class="info-value"><%= student.DeutschLevel || '—' %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= __('nsl_result') %></span>
                                <span class="info-value"><%= displayScore %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= __('integration_level') %></span>
                                <span class="info-value"><%= actualLevel %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><%= __('availability') %></span>
                                <span class="info-value"><%= actualAvailability %></span>
                            </div>

                            <% if (student.Strength1 || student.Strength2 || student.Strength3) { %>
                            <div style="margin-top: 15px; border-top: 2px solid var(--border-color); padding-top: 10px;">
                                <span class="info-label" style="display:block; margin-bottom:8px;">Superpowers</span>
                                <ul style="list-style-type: square; margin-left: 20px; font-weight: 600; color: var(--text-main); font-size: 13px;">
                                    <% if (student.Strength1) { %><li><%= student.Strength1 %></li><% } %>
                                    <% if (student.Strength2) { %><li><%= student.Strength2 %></li><% } %>
                                    <% if (student.Strength3) { %><li><%= student.Strength3 %></li><% } %>
                                </ul>
                            </div>
                            <% } %>
                        </div>
                        <div class="card-actions">
                            <% if (student.SetcardLink) { %>
                                <a href="<%= student.SetcardLink %>" target="_blank" class="btn-nsl-brutal primary" style="display: block; width: 100%;"><%= __('download_pdf') %></a>
                            <% } %>
                            <% if (student.YouTubeLink || student.DriveVideoLink) { %>
                                <a href="<%= student.YouTubeLink || student.DriveVideoLink %>" target="_blank" class="btn-nsl-brutal" style="display: block; width: 100%;"><%= __('view_video') %></a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No candidates available for your selected criteria.</p>
            <% } %>
        </div>
        <div id="paginationContainer" style="display: flex; justify-content: center; gap: 10px; margin-top: 30px; margin-bottom: 20px; flex-wrap: wrap;"></div>
    </div>
    <script>
        let currentRankFilter = 'ALL';
        let currentPage = 1;
        let itemsPerPage = window.innerWidth <= 768 ? 10 : 20;
        let fullInfoOnly = true;

        function toggleFullInfo(btn) {
            fullInfoOnly = !fullInfoOnly;
            const indicator = document.getElementById('fullInfoIndicator');
            if (fullInfoOnly) {
                btn.style.background = 'var(--text-main)';
                btn.style.color = '#fff';
                indicator.style.background = '#0f0';
                indicator.style.borderColor = '#fff';
            } else {
                btn.style.background = '#fff';
                btn.style.color = 'var(--text-main)';
                indicator.style.background = '#ccc';
                indicator.style.borderColor = 'var(--text-main)';
            }
            currentPage = 1;
            filterStudents();
        }

        window.addEventListener('resize', () => {
            let newItemsPerPage = window.innerWidth <= 768 ? 10 : 20;
            if (newItemsPerPage !== itemsPerPage) {
                itemsPerPage = newItemsPerPage;
                currentPage = 1;
                filterStudents();
            }
        });

        function changePage(page) {
            currentPage = page;
            filterStudents();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function filterByRank(rank, btn) {
            currentRankFilter = rank;
            currentPage = 1;
            
            // Update active state of buttons
            const buttons = document.getElementById('rankTabs').getElementsByTagName('button');
            for (let i = 0; i < buttons.length; i++) {
                buttons[i].style.background = 'transparent';
                buttons[i].style.color = 'var(--text-main)';
                buttons[i].classList.remove('active');
            }
            btn.style.background = 'var(--text-main)';
            btn.style.color = '#fff';
            btn.classList.add('active');

            filterStudents();
        }

        function filterStudents() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const profFilter = document.getElementById('professionFilter').value.toUpperCase();
            const sortFilter = document.getElementById('sortFilter').value;
            const grid = document.getElementById('studentsGrid');
            if (!grid) return;
            let cards = Array.from(grid.getElementsByClassName('nsl-grid-card'));
            
            let filteredCards = [];
            window.currentFilteredIds = [];
            
            for (let i = 0; i < cards.length; i++) {
                const card = cards[i];
                const text = card.innerText.toLowerCase();
                const cardRank = card.getAttribute('data-rank');
                const cardProf = card.getAttribute('data-prof');
                const cardHasVideo = card.getAttribute('data-hasvideo');
                const cardHasPhoto = card.getAttribute('data-hasphoto');
                
                const matchesSearch = text.includes(query);
                const matchesRank = currentRankFilter === 'ALL' || cardRank === currentRankFilter;
                let matchesProf = profFilter === 'ALL';
                if (!matchesProf) {
                    const keywords = profFilter.split(',');
                    matchesProf = keywords.some(kw => cardProf.toUpperCase().includes(kw.trim()));
                }
                const matchesVideo = sortFilter !== 'HAS_VIDEO' || cardHasVideo === 'true';

                let matchesFullInfo = true;
                if (fullInfoOnly) {
                    matchesFullInfo = (cardHasVideo === 'true' && cardHasPhoto === 'true');
                }

                if (matchesSearch && matchesRank && matchesProf && matchesVideo && matchesFullInfo) {
                    filteredCards.push(card);
                    window.currentFilteredIds.push(card.getAttribute('data-studentid'));
                } else {
                    card.style.display = 'none';
                }
            }
            
            if (sortFilter === 'SCORE_DESC') {
                filteredCards.sort((a, b) => parseFloat(b.getAttribute('data-score') || 0) - parseFloat(a.getAttribute('data-score') || 0));
            } else if (sortFilter === 'NAME_ASC') {
                filteredCards.sort((a, b) => a.getAttribute('data-name').localeCompare(b.getAttribute('data-name')));
            } else if (sortFilter === 'NAME_DESC') {
                filteredCards.sort((a, b) => b.getAttribute('data-name').localeCompare(a.getAttribute('data-name')));
            } else {
                filteredCards.sort((a, b) => parseInt(a.getAttribute('data-index') || 0) - parseInt(b.getAttribute('data-index') || 0));
            }
            
            cards.forEach(card => grid.appendChild(card));
            
            const totalItems = filteredCards.length;
            const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;
            
            if (currentPage > totalPages) {
                currentPage = totalPages;
            }

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;

            filteredCards.forEach((card, index) => {
                if (index >= startIndex && index < endIndex) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
            
            const countBadge = document.getElementById('studentCount');
            if (countBadge) {
                countBadge.innerText = totalItems + ' <%= __('candidates_count') %>';
            }

            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            let container = document.getElementById('paginationContainer');
            if (!container) return;
            container.innerHTML = '';
            
            if (totalPages <= 1) return;

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.className = 'btn-nsl-brutal';
                btn.innerText = i;
                btn.style.padding = '8px 12px';
                if (i === currentPage) {
                    btn.style.background = 'var(--text-main)';
                    btn.style.color = '#fff';
                } else {
                    btn.style.background = 'transparent';
                    btn.style.color = 'var(--text-main)';
                }
                btn.onclick = () => changePage(i);
                container.appendChild(btn);
            }
        }
        // Initial call to apply fullInfoOnly immediately
        filterStudents();
    </script>
    <%- include('../partials/chat_widget') %>
</body>
</html>
