<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'de' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="<%= appBaseUrl %>">
    <title>NSL Portal – Candidate Setcard</title>
    <link rel="icon" type="image/png" href="assets/design/favicon_square.png?v=10">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        .close-btn {
            background: var(--nsl-yellow, #ffc107); 
            border: 3px solid var(--text-main, #1a1a1a); 
            color: var(--text-main, #1a1a1a); 
            width: 40px; 
            height: 40px; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            font-size: 28px; 
            cursor: pointer; 
            font-weight: bold; 
            border-radius: 50%; 
            box-shadow: 4px 4px 0px var(--text-main, #1a1a1a); 
            transition: all 0.1s ease-out; 
            padding: 0;
        }
        .close-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--text-main, #1a1a1a);
        }
        .close-btn:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px var(--text-main, #1a1a1a);
        }
        .lang-link {
            color: #fff !important; 
            text-decoration: none !important; 
            padding: 6px 12px !important; 
            border-radius: 20px !important;
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
            display: inline-block !important;
            font-weight: 500 !important;
            opacity: 0.6 !important;
        }
        .lang-link.lang-active {
            font-weight: 900 !important;
            opacity: 1 !important;
            background: rgba(255, 255, 255, 0.15) !important;
        }
        .lang-link:hover {
            background: var(--nsl-yellow, #ffc107) !important;
            color: var(--text-main, #1a1a1a) !important;
            transform: scale(1.15) !important;
            opacity: 1 !important;
        }
        .lang-link:active {
            transform: scale(0.9) !important;
        }

        /* Modal classes for mobile compatibility */
        #modalContent.modal-pdf {
            max-width: 1000px;
            max-width: min(1000px, calc((95vh - 70px) * 4 / 3));
        }
        #iframeContainer.modal-pdf {
            padding-bottom: 75%; /* 4:3 Aspect Ratio */
        }
        #modalContent.modal-video {
            max-width: 900px;
            max-width: min(900px, calc((95vh - 70px) * 16 / 9));
        }
        #iframeContainer.modal-video {
            padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
        }

        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #f2a900;
            --nsl-dark: #222;
            --nsl-light: #f8f9fa;
            --text-main: #1a1a1a;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body, html {
            /* Remove the weird checkered background, just use a clean soft gray like a real app */
            background-color: #f0f2f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--nsl-dark);
            overflow-x: hidden;
            width: 100%;
        }

        .container {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* Top Wavy Banner - Fixed to not stretch weirdly */
        .wavy-header {
            position: relative;
            height: 180px;
            width: 100%;
            overflow: hidden;
            z-index: 1;
        }
        
        .header-controls {
            position: absolute;
            top: 20px;
            right: 40px;
            z-index: 100;
            display: flex;
            gap: 20px;
            align-items: center;
        }
        
        .lang-switch {
            background: rgba(0,0,0,0.3);
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 14px;
        }

        .header-link {
            color: #fff;
            text-decoration: none;
            font-weight: 700;
            background: transparent;
            border: 2px solid #fff;
            padding: 6px 15px;
            border-radius: 5px;
            font-size: 14px;
            transition: 0.3s;
        }
        
        .header-link:hover { background: rgba(0,0,0,0.2); }



        /* Main Card Container */
        .card-inner {
            background: white;
            max-width: 1050px; /* Perfect width for 1 photo */
            margin: 40px auto 60px; /* No overlap with the wave */
            border-radius: 24px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            position: relative;
            z-index: 10;
            padding: 50px 60px;
            display: flex;
            flex-direction: column;
            min-height: 600px;
        }

        .card-photos-2 {
            max-width: 1250px; /* Expanded for 2 photos */
        }
        
        .card-photos-0 {
            max-width: 800px; /* Compact width for no photos */
        }

        .card-logo-box {
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: nowrap;
            gap: 20px;
            width: 100%;
            container-type: inline-size;
        }
        .card-logo-box img {
            height: clamp(40px, 6vw, 80px);
            flex-shrink: 0;
            object-fit: contain;
        }
        .card-profession-title {
            font-size: clamp(12px, 4.5cqi, 36px);
            font-weight: 900;
            color: var(--nsl-red);
            text-transform: uppercase;
            letter-spacing: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-align: right;
            flex-shrink: 1;
        }

        /* Profile Content Layout */
        .profile-flex {
            display: flex;
            gap: 50px;
            align-items: flex-start;
        }

        /* 0 Photos Layout */
        .layout-photos-0 {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .layout-photos-0 .info-section {
            align-items: center;
            width: 100%;
        }
        .layout-photos-0 .info-grid {
            margin: 0 auto 30px;
        }

        /* 2 Photos Layout */
        .layout-photos-2 {
            gap: 40px; /* Better gap between photos and text */
        }
        .layout-photos-2 .superpowers-box {
            max-width: 100%;
        }

        /* Photos Section */
        .photos-wrapper {
            display: flex;
            gap: 15px;
        }

        .photo-box {
            width: 260px;
            height: 350px;
            border-radius: 20px;
            border: 4px solid var(--nsl-gold);
            overflow: hidden;
            background: #f8f9fa;
            flex-shrink: 0;
            box-shadow: 0 10px 25px rgba(242, 169, 0, 0.15);
        }

        .photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Information Section */
        .info-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .student-name {
            font-size: 38px;
            font-weight: 900;
            color: var(--nsl-gold);
            margin-bottom: 30px;
            letter-spacing: -0.5px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: auto auto 1fr;
            column-gap: 30px;
            row-gap: 16px;
            font-size: 19px;
            margin-bottom: 20px;
            width: fit-content;
        }

        .info-label { font-weight: 800; color: #111; text-align: left; }
        .info-sep { font-weight: 600; color: #555; }
        .info-value { font-weight: 500; color: #333; text-align: left; }

        /* Superpowers */
        .superpowers-box {
            background: var(--nsl-gold);
            border-radius: 20px;
            padding: 25px 35px;
            text-align: center;
            margin-top: 20px;
            box-shadow: 0 10px 20px rgba(242, 169, 0, 0.2);
            /* Align left to match Canva */
            width: 100%;
            max-width: 480px;
        }
        
        .sp-title {
            color: var(--nsl-red);
            font-weight: 900;
            font-size: 20px;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sp-list p {
            font-weight: 800;
            font-size: 16px;
            color: #111;
            line-height: 1.8;
            text-align: left;
        }

        /* Footer Text */
        .disclaimer-text {
            text-align: center;
            font-size: 13px;
            font-weight: 500;
            color: #666;
            margin-top: 40px;
            padding: 0 60px;
            line-height: 1.5;
        }

        /* Video Button */
        .video-action {
            text-align: center;
            margin-top: 40px;
            margin-bottom: 10px;
        }

        .video-btn {
            display: inline-block;
            background: var(--nsl-red);
            color: white;
            text-decoration: underline;
            text-underline-offset: 4px;
            padding: 18px 45px;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 800;
            box-shadow: 0 10px 25px rgba(204, 31, 31, 0.35);
            transition: transform 0.2s, background 0.2s;
        }

        .video-btn:hover {
            background: #a11616;
            transform: translateY(-3px);
        }

        /* Bottom Wave */
        .wavy-footer {
            height: 80px;
            margin-top: auto;
            position: relative;
            overflow: hidden;
        }

        @media (max-width: 900px) {
            .wavy-header { height: 120px; }
            .header-controls {
                right: 15px;
                top: 15px;
                gap: 10px;
            }
            .lang-switch {
                padding: 6px 10px;
                font-size: 12px;
            }
            .header-link {
                padding: 5px 10px;
                font-size: 12px;
            }
            .card-inner { margin: 20px 15px 30px; padding: 30px 20px; }
            .profile-flex { flex-direction: column; align-items: center; gap: 30px; }
            .photos-wrapper { flex-wrap: wrap; justify-content: center; }
            .photo-box { width: 200px; height: 266px; }
            .student-name { font-size: 28px; text-align: center; margin-bottom: 20px; }
            
            /* Fix Grid Overflow on Mobile */
            .info-grid { 
                font-size: 15px; 
                column-gap: 10px; 
                width: 100%; 
                max-width: 100%;
                overflow-wrap: break-word;
                word-wrap: break-word;
            }
            .info-label { max-width: 140px; }
            
            .card-logo-box { margin-bottom: 20px; gap: 10px; }
            /* card-logo-box img and title handled by clamp now */
            .superpowers-box { max-width: 100%; padding: 20px; }
            
            .video-action { margin-top: 25px; margin-bottom: 15px; }
            .video-btn { padding: 14px 24px; font-size: 16px; width: 90%; max-width: 300px; display: inline-block; white-space: normal; line-height: 1.3; }
            .disclaimer-text { font-size: 11px; margin-top: 20px; padding: 0; width: 100%; line-height: 1.4; color: #777; }
        }

        /* Progress Bar */
        .progress-container {
            margin-top: 40px;
            width: 100%;
        }
        .progress-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--nsl-red);
            text-transform: uppercase;
            margin-bottom: 25px;
            text-align: center;
        }
        .stepper {
            display: flex;
            justify-content: space-between;
            position: relative;
            width: 100%;
        }
        .stepper::before {
            content: '';
            position: absolute;
            top: 15px;
            left: 0;
            right: 0;
            height: 4px;
            background: #e0e0e0;
            z-index: 1;
        }
        .stepper-progress {
            position: absolute;
            top: 15px;
            left: 0;
            height: 4px;
            background: var(--nsl-gold);
            z-index: 2;
            transition: width 0.5s ease;
        }
        .step {
            position: relative;
            z-index: 3;
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 16.66%;
        }
        .step-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #e0e0e0;
            border: 4px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 14px;
            color: #666;
            transition: 0.3s;
        }
        .step.active .step-circle {
            background: var(--nsl-gold);
            color: #fff;
            border-color: #fff;
            box-shadow: 0 0 0 4px rgba(242, 169, 0, 0.3);
        }
        .step.completed .step-circle {
            background: var(--nsl-gold);
            color: #fff;
            border-color: #fff;
        }
        .step-label {
            margin-top: 10px;
            font-size: 12px;
            font-weight: 700;
            color: #777;
            text-align: center;
            line-height: 1.3;
        }
        .step.active .step-label {
            color: var(--nsl-dark);
        }
        @media (max-width: 900px) {
            .progress-container { margin-top: 30px; }
            .step-label { font-size: 10px; }
            .step-circle { width: 28px; height: 28px; font-size: 12px; border-width: 3px; }
            .stepper::before, .stepper-progress { top: 12px; }
        }
    </style>
</head>
<body>
    <% 
        // Helper to format missing or zero values as "Ausstehend"
        function formatValue(val) {
            if (val === undefined || val === null || val === '' || val === '0' || val === 0 || val === '—' || val === 'Pending') {
                return 'Ausstehend';
            }
            return val;
        }

        // Helper calculations
        // Extract birth year from Student ID (e.g., ANG_Huyen_NGUYEN_03.10.2006 -> 2006)
        let birthYear = 'N/A';
        const yearMatch = student.StudentID ? student.StudentID.match(/\d{4}$/) : null;
        if (yearMatch) birthYear = yearMatch[0];

        // Determine Level and Score from the actual data
        let actualScore = student.NSLScore || '0'; 
        let actualLevel = student.NSLGrade || '—';
        
        // Availability
        let actualAvailability = student.AvailableFrom;
        if (!actualAvailability || actualAvailability.trim() === '') {
            actualAvailability = '—';
        }
        
        // Deutsch Level
        let actualDeutsch = student.DeutschLevel;
        if (!actualDeutsch || actualDeutsch.trim() === '' || actualDeutsch === '0' || actualDeutsch === '—' || actualDeutsch === 'Pending') {
            actualDeutsch = 'B1';
        }
        
        let rawVideo = student['Introduction Video'] || student.YouTubeLink || student.DriveVideoLink || '';
        // It has a video if the field is not empty, not 'FALSE', and looks like a URL (longer than 5 chars)
        let hasVideo = rawVideo && rawVideo.trim().length > 5 && rawVideo.toUpperCase() !== 'FALSE';
        let videoLink = hasVideo ? rawVideo.trim() : '#';
    %>

    <div class="container">
        <!-- Absolute Header Controls (Moved out of wavy-header to escape z-index trapping and float above modals) -->
        <div class="header-logo" style="position: absolute; top: 50px; left: 60px; z-index: 10000;">
            <img src="assets/design/NSL_logo_mid.png" alt="NSL" style="height: 50px;">
        </div>
        <div class="header-controls" style="z-index: 10000;">
            <div class="lang-switch" style="background: rgba(0,0,0,0.3); padding: 5px 10px; border-radius: 20px; display: flex; align-items: center; gap: 5px; margin-right: 20px;">
                <a href="javascript:void(0)" onclick="window.location.search='?lang=de'" class="lang-link <%= typeof lang !== 'undefined' && lang === 'de' ? 'lang-active' : '' %>">DE</a> <span style="color:#fff;opacity:0.5">|</span>
                <a href="javascript:void(0)" onclick="window.location.search='?lang=en'" class="lang-link <%= typeof lang !== 'undefined' && lang === 'en' ? 'lang-active' : '' %>">EN</a> <span style="color:#fff;opacity:0.5">|</span>
                <a href="javascript:void(0)" onclick="window.location.search='?lang=vi'" class="lang-link <%= typeof lang !== 'undefined' && lang === 'vi' ? 'lang-active' : '' %>">VI</a>
            </div>
            <% if (typeof partner !== 'undefined' && partner) { %>
                <a href="partner/dashboard" class="header-link">Back</a>
            <% } else { %>
                <a href="login" class="header-link"><%= __('logout') %></a>
            <% } %>
        </div>

        <!-- Top Banner Waves -->
        <div class="wavy-header">
            <svg viewBox="0 0 1000 140" preserveAspectRatio="none" style="width:100%; height:100%;">
                <!-- Yellow wave (thick on left) -->
                <path d="M0,0 L1000,0 L1000,80 Q500,140 0,140 Z" fill="#f2a900" />
                <!-- Red wave (thick on right) -->
                <path d="M0,0 L1000,0 L1000,140 Q600,140 200,0 Z" fill="#cc1f1f" />
            </svg>
        </div>

        <% 
            let photoCount = 0;
            if (student.PhotoLink && student.PhotoLink.trim() !== '') photoCount++;
            if (student.ActivityPhotoLink && student.ActivityPhotoLink.trim() !== '') photoCount++;
        %>
        <div class="card-inner card-photos-<%= photoCount %>">
            <div class="card-logo-box">
                <img src="assets/design/Logo_Mid_PersonalKampagne.png" alt="NSL">
                <div class="card-profession-title">BERUFE - <%= (student['Nghề nghiệp'] || student.Profession || student.ProfessionCode || 'FACHVERKÄUFERIN').toUpperCase() %></div>
            </div>

            <div class="profile-flex layout-photos-<%= photoCount %>">
                <!-- Photos Section -->
                <div class="photos-wrapper">
                    <!-- Portrait Photo Frame -->
                    <% if (student.PhotoLink && student.PhotoLink.trim() !== '') { %>
                    <div class="photo-box">
                        <img src="photos/<%= encodeURIComponent(student.FullName) %>.jpg" onerror="this.onerror=null; this.src='proxy/students/<%= student.StudentID %>/photo'; this.addEventListener('error', function(){this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%23f0f0f0\'/><text x=\'50%\' y=\'50%\' fill=\'%23999\' font-family=\'sans-serif\' font-size=\'14\' text-anchor=\'middle\' dominant-baseline=\'middle\'>No Photo</text></svg>'});" alt="Portrait">
                    </div>
                    <% } %>
                    
                    <!-- Activity Photo Frame (Only shows if there is a link) -->
                    <% if (student.ActivityPhotoLink && student.ActivityPhotoLink.trim() !== '') { %>
                    <div class="photo-box">
                        <img src="proxy/students/<%= student.StudentID %>/activity-photo" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%23e0e0e0\'/><text x=\'50%\' y=\'50%\' fill=\'%23888\' font-family=\'sans-serif\' font-size=\'14\' text-anchor=\'middle\' dominant-baseline=\'middle\'>Activity Photo</text></svg>'" alt="Activity">
                    </div>
                    <% } %>
                </div>

                <!-- Info Section -->
                <div class="info-section">
                    <h2 class="student-name"><%= student['Short Name'] || student.FullName %></h2>
                    
                    <div class="info-grid">
                        <div class="info-label"><%= __('date_of_birth') || 'Date of Birth' %></div><div class="info-sep">:</div><div class="info-value"><%= student.DOB || '—' %></div>
                        <div class="info-label"><%= __('deutsch_level') %></div><div class="info-sep">:</div><div class="info-value"><%= formatValue(actualDeutsch) %></div>
                        <div class="info-label"><%= __('nsl_result') %></div><div class="info-sep">:</div><div class="info-value"><%= formatValue(actualScore) %></div>
                        <div class="info-label"><%= __('integration_level') %></div><div class="info-sep">:</div><div class="info-value"><%= formatValue(actualLevel) %></div>
                        <div class="info-label"><%= __('availability') %></div><div class="info-sep">:</div><div class="info-value"><%= actualAvailability %></div>
                    </div>

                    <% 
                        let sp1 = student.Strength1 || student['Superpower 1'] || student['Strength 1'] || '';
                        let sp2 = student.Strength2 || student['Superpower 2'] || student['Strength 2'] || '';
                        let sp3 = student.Strength3 || student['Superpower 3'] || student['Strength 3'] || '';
                    %>
                    <% if (sp1 || sp2 || sp3) { %>
                    <!-- Superpowers -->
                    <div class="superpowers-box">
                        <div class="sp-title"><%= __('superpowers') %></div>
                        <div class="sp-list">
                            <% if (sp1) { %><p>1. <%= sp1 %></p><% } %>
                            <% if (sp2) { %><p>2. <%= sp2 %></p><% } %>
                            <% if (sp3) { %><p>3. <%= sp3 %></p><% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <% 
                let currentStep = parseInt(student.ProgressStatus) || 1;
                if (currentStep < 1) currentStep = 1;
                if (currentStep > 6) currentStep = 6;
                let progressPercent = ((currentStep - 1) / 5) * 100;
                
                const steps = [
                    __('prog_1'),
                    __('prog_2'),
                    __('prog_3'),
                    __('prog_4'),
                    __('prog_5'),
                    __('prog_6')
                ];
            %>
            <div class="progress-container">
                <div class="progress-title"><%= __('prog_title') %></div>
                <div class="stepper">
                    <div class="stepper-progress" style="width: <%= progressPercent %>%;"></div>
                    <% for(let i=1; i<=6; i++) { %>
                        <div class="step <%= currentStep === i ? 'active' : '' %> <%= currentStep > i ? 'completed' : '' %>">
                            <div class="step-circle"><%= i %></div>
                            <div class="step-label"><%- steps[i-1] %></div>
                        </div>
                    <% } %>
                </div>
            </div>

            <% if (hasVideo) { %>
            <div class="video-action">
                <button onclick="openModal('<%= videoLink %>', 'video')" class="video-btn" style="border:none; cursor:pointer; width:100%;">
                    <%= __('view_video') %>
                </button>
            </div>
            <% } %>

            <% if (typeof candidateBookingLink !== 'undefined' && candidateBookingLink && candidateBookingLink.trim() !== '' && parseInt(student.ProgressStatus || 1) >= 4) { %>
            <!-- ONBOARDING CTA FOR CANDIDATES -->
            <div style="text-align: center; margin-top: 30px; margin-bottom: 20px;">
                <p style="font-size: 14px; font-weight: 600; color: var(--nsl-red); margin-bottom: 15px; text-transform: uppercase;">
                    <%= __('ready_for_next_step') %>
                </p>
                <a href="<%= candidateBookingLink %>" target="_blank" class="btn-nsl-brutal" style="display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 15px 30px; border-radius: 50px; background: var(--text-main); color: #fff; border: 2px solid var(--text-main); text-decoration: none;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span><%= __('book_onboarding') %></span>
                </a>
            </div>
            <% } %>

            <p class="disclaimer-text">
                <%= __('disclaimer') %>
            </p>

        </div>

        <!-- Bottom Wave -->
        <div class="wavy-footer">
            <svg viewBox="0 0 1000 60" preserveAspectRatio="none" style="width:100%; height:100%;">
                <path d="M0,20 Q500,70 1000,20 L1000,60 L0,60 Z" fill="#1a1a1a" />
            </svg>
        </div>
    </div>

    <div id="iframeModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 9999; justify-content: center; align-items: center; padding: 20px; box-sizing: border-box; overflow-y: auto;">
        <div id="modalContent" style="position: relative; width: 100%; max-width: 900px; background: #fff; border: 4px solid var(--text-main, #1a1a1a); border-radius: 0; overflow: hidden; display: flex; flex-direction: column; box-shadow: 12px 12px 0px var(--text-main, #1a1a1a); transition: transform 0.2s; margin: auto;">
            <div style="background: var(--nsl-red, #cc1f1f); color: white; padding: 15px 25px; display: flex; justify-content: space-between; align-items: center; border-bottom: 4px solid var(--text-main, #1a1a1a);">
                <h3 id="modalTitle" style="margin: 0; font-weight: 900; font-size: 20px; text-transform: uppercase; letter-spacing: 1px;">PREVIEW</h3>
                <button onclick="closeModal()" class="close-btn">&times;</button>
            </div>
            <div id="iframeContainer" style="width: 100%; background: #000; position: relative;">
                <iframe id="modalIframe" style="width: 100%; height: 100%; border: none; position: absolute; top: 0; left: 0;" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen referrerpolicy="strict-origin-when-cross-origin"></iframe>
            </div>
        </div>
    </div>

    <script>
        function getEmbedUrl(url) {
            if (!url) return '';
            try {
                const lowerUrl = url.toLowerCase();
                if (lowerUrl.includes('youtube.com') || lowerUrl.includes('youtu.be')) {
                    if (lowerUrl.includes('/embed/')) return url.replace('youtube.com', 'youtube-nocookie.com');
                    const ytRegex = /(?:youtu\.be\/|youtube\.com\/(?:watch\?(?:.*&)?v=|shorts\/))([\w-]{11})/i;
                    const match = url.match(ytRegex);
                    if (match && match[1]) {
                        return `https://www.youtube-nocookie.com/embed/${match[1]}?rel=0`;
                    }
                }
                
                if (lowerUrl.includes('drive.google.com/file/d/')) {
                    const parts = url.split('/');
                    const idIndex = parts.indexOf('d') + 1;
                    if (idIndex > 0 && parts[idIndex]) {
                        return `https://drive.google.com/file/d/${parts[idIndex]}/preview`;
                    }
                }
                if (url.includes('drive.google.com/open')) {
                     const urlObj = new URL(url);
                     const id = urlObj.searchParams.get('id');
                     if (id) return `https://drive.google.com/file/d/${id}/preview`;
                }
                return url;
            } catch (e) {
                return url;
            }
        }

        function openModal(url, type) {
            const titleEl = document.getElementById('modalTitle');
            const modalContent = document.getElementById('modalContent');
            const iframeContainer = document.getElementById('iframeContainer');
            
            // Clear previous classes
            if (modalContent) modalContent.className = '';
            if (iframeContainer) iframeContainer.className = '';

            if (type === 'pdf') {
                if (titleEl) titleEl.innerText = `<%= __('candidate_setcard') %>`;
                if (modalContent) modalContent.classList.add('modal-pdf');
                if (iframeContainer) iframeContainer.classList.add('modal-pdf');
            } else {
                if (titleEl) titleEl.innerText = `<%= __('candidate_video') %>`;
                if (modalContent) modalContent.classList.add('modal-video');
                if (iframeContainer) iframeContainer.classList.add('modal-video');
            }

            const embedUrl = getEmbedUrl(url);
            const modal = document.getElementById('iframeModal');
            const iframe = document.getElementById('modalIframe');
            iframe.src = embedUrl;
            document.getElementById('iframeModal').style.display = 'flex';
        }

        function closeModal() {
            const modal = document.getElementById('iframeModal');
            const iframe = document.getElementById('modalIframe');
            iframe.src = '';
            modal.style.display = 'none';
        }
        
        // Close modal when clicking outside
        document.getElementById('iframeModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });
    </script>

    <% if (typeof needsGdprConsent !== 'undefined' && needsGdprConsent) { %>
    <!-- GDPR CONSENT MODAL -->
    <div id="gdprModal" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.8); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
        <div style="background: white; border: 4px solid var(--text-main, #1a1a1a); width: 95%; max-width: 700px; max-height: 90vh; display: flex; flex-direction: column; box-shadow: 8px 8px 0px var(--text-main, #1a1a1a);">
            <!-- Header -->
            <div style="background: linear-gradient(135deg, var(--nsl-gold, #f2a900) 0%, var(--nsl-red, #cc1f1f) 100%); color: white; padding: 20px; border-bottom: 4px solid var(--text-main, #1a1a1a); text-shadow: 1px 1px 2px rgba(0,0,0,0.3);">
                <h2 style="margin: 0; font-size: 22px; font-weight: 900; text-transform: uppercase;"><%= __('gdpr_title') %></h2>
            </div>
            
            <!-- Body -->
            <div style="padding: 20px; overflow-y: auto; flex: 1;" id="gdprFormSection">
                <div style="font-size: 13px; margin-bottom: 20px; line-height: 1.6; color: #333; background: #f8f9fa; padding: 15px; border: 1px solid #ddd; max-height: 300px; overflow-y: auto;">
                    <%- __('gdpr_body') %>
                </div>

                <form action="/profile/gdpr-consent" method="POST" id="gdprForm">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="gdpr_signature" id="gdpr_signature">
                    
                    <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px;">
                        <label style="display: flex; align-items: flex-start; cursor: pointer; gap: 10px;">
                            <input type="checkbox" class="gdpr-chk" required style="margin-top: 4px; transform: scale(1.2);">
                            <span style="font-size: 13px; font-weight: 600;"><%= __('gdpr_chk1') %></span>
                        </label>
                        <label style="display: flex; align-items: flex-start; cursor: pointer; gap: 10px;">
                            <input type="checkbox" class="gdpr-chk" required style="margin-top: 4px; transform: scale(1.2);">
                            <span style="font-size: 13px; font-weight: 600;"><%= __('gdpr_chk2') %></span>
                        </label>
                        <label style="display: flex; align-items: flex-start; cursor: pointer; gap: 10px;">
                            <input type="checkbox" class="gdpr-chk" required style="margin-top: 4px; transform: scale(1.2);">
                            <span style="font-size: 13px; font-weight: 600;"><%= __('gdpr_chk3') %></span>
                        </label>
                        <label style="display: flex; align-items: flex-start; cursor: pointer; gap: 10px;">
                            <input type="checkbox" class="gdpr-chk" required style="margin-top: 4px; transform: scale(1.2);">
                            <span style="font-size: 13px; font-weight: 600;"><%= __('gdpr_chk4') %></span>
                        </label>
                        <label style="display: flex; align-items: flex-start; cursor: pointer; gap: 10px;">
                            <input type="checkbox" class="gdpr-chk" required style="margin-top: 4px; transform: scale(1.2);">
                            <span style="font-size: 13px; font-weight: 600;"><%= __('gdpr_chk5') %></span>
                        </label>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                        <div>
                            <label style="display: block; font-weight: 700; margin-bottom: 5px; font-size: 12px;"><%= __('gdpr_fullname') %></label>
                            <input type="text" name="gdpr_fullname" required style="width: 100%; padding: 10px; border: 2px solid var(--text-main, #1a1a1a); font-size: 14px;" placeholder="<%= __('gdpr_fullname_ph') %>">
                        </div>
                        <div>
                            <label style="display: block; font-weight: 700; margin-bottom: 5px; font-size: 12px;"><%= __('gdpr_dob') %></label>
                            <input type="text" name="gdpr_dob" required style="width: 100%; padding: 10px; border: 2px solid var(--text-main, #1a1a1a); font-size: 14px;" placeholder="<%= __('gdpr_dob_ph') %>" value="<%= student.DOB || '' %>">
                        </div>
                        <div>
                            <label style="display: block; font-weight: 700; margin-bottom: 5px; font-size: 12px;"><%= __('gdpr_centercode') %></label>
                            <input type="text" name="gdpr_centercode" required style="width: 100%; padding: 10px; border: 2px solid var(--text-main, #1a1a1a); font-size: 14px;" placeholder="Ex: NSL" value="<%= student.CenterCode || '' %>">
                        </div>
                        <div>
                            <label style="display: block; font-weight: 700; margin-bottom: 5px; font-size: 12px;"><%= __('gdpr_email') %></label>
                            <input type="email" name="gdpr_email" required style="width: 100%; padding: 10px; border: 2px solid var(--text-main, #1a1a1a); font-size: 14px;" placeholder="<%= __('gdpr_email_ph') %>">
                        </div>
                    </div>
                    
                    <button type="submit" id="gdprSubmitBtn" disabled style="width: 100%; background: #ccc; color: #666; border: 3px solid #999; padding: 15px; font-size: 16px; font-weight: 800; text-transform: uppercase; cursor: not-allowed; transition: all 0.2s;">
                        <%= __('gdpr_submit') %>
                    </button>
                </form>
            </div>

            <!-- Signature Pad Section (Hidden initially) -->
            <div style="padding: 20px; display: none; flex-direction: column; align-items: center;" id="gdprSignatureSection">
                <h3 style="margin-top: 0; color: var(--text-main, #1a1a1a);"><%= __('gdpr_signature_title', 'VUI LÒNG KÝ TÊN CỦA BẠN') %></h3>
                <div style="border: 3px dashed #ccc; background: #fafafa; margin-bottom: 15px; border-radius: 8px; width: 100%; max-width: 400px; height: 200px;">
                    <canvas id="signatureCanvas" style="width: 100%; height: 100%; touch-action: none;"></canvas>
                </div>
                <div style="display: flex; gap: 15px; width: 100%; max-width: 400px;">
                    <button type="button" id="clearSignatureBtn" style="flex: 1; padding: 12px; background: #f5f5f5; border: 2px solid #ccc; font-weight: bold; cursor: pointer;">
                        Xóa (Clear)
                    </button>
                    <button type="button" id="submitSignatureBtn" style="flex: 2; padding: 12px; background: var(--text-main, #1a1a1a); color: white; border: 2px solid var(--text-main, #1a1a1a); font-weight: bold; cursor: pointer;">
                        Hoàn tất (Complete)
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Include Signature Pad library -->
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const checkboxes = document.querySelectorAll('.gdpr-chk');
            const textInputs = document.querySelectorAll('input[name="gdpr_fullname"], input[name="gdpr_dob"], input[name="gdpr_centercode"], input[name="gdpr_email"]');
            const submitBtn = document.getElementById('gdprSubmitBtn');
            
            if (checkboxes.length > 0 && submitBtn) {
                function checkAll() {
                    let allChecked = true;
                    checkboxes.forEach(chk => {
                        if (!chk.checked) allChecked = false;
                    });
                    
                    let allFilled = true;
                    textInputs.forEach(input => {
                        if (input.value.trim() === '') allFilled = false;
                    });
                    
                    if (allChecked && allFilled) {
                        submitBtn.style.background = 'var(--text-main, #1a1a1a)';
                        submitBtn.style.color = '#fff';
                        submitBtn.style.borderColor = 'var(--text-main, #1a1a1a)';
                        submitBtn.style.cursor = 'pointer';
                        submitBtn.disabled = false;
                    } else {
                        submitBtn.style.background = '#ccc';
                        submitBtn.style.color = '#666';
                        submitBtn.style.borderColor = '#999';
                        submitBtn.style.cursor = 'not-allowed';
                        submitBtn.disabled = true;
                    }
                }
                
                checkboxes.forEach(chk => chk.addEventListener('change', checkAll));
                textInputs.forEach(input => input.addEventListener('input', checkAll));
                
                // Signature Pad Logic
                const formSection = document.getElementById('gdprFormSection');
                const sigSection = document.getElementById('gdprSignatureSection');
                const form = document.getElementById('gdprForm');
                const sigInput = document.getElementById('gdpr_signature');
                const canvas = document.getElementById('signatureCanvas');
                let signaturePad;

                submitBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    if (submitBtn.disabled) return;
                    
                    formSection.style.display = 'none';
                    sigSection.style.display = 'flex';
                    
                    setTimeout(() => {
                        // Resize canvas properly after container is visible
                        const ratio = Math.max(window.devicePixelRatio || 1, 1);
                        canvas.width = canvas.offsetWidth * ratio;
                        canvas.height = canvas.offsetHeight * ratio;
                        canvas.getContext("2d").scale(ratio, ratio);

                        if (!signaturePad) {
                            signaturePad = new SignaturePad(canvas, {
                                penColor: "rgb(0, 0, 0)"
                            });
                        } else {
                            signaturePad.clear();
                        }
                    }, 50);
                });

                document.getElementById('clearSignatureBtn').addEventListener('click', function() {
                    if (signaturePad) signaturePad.clear();
                });

                const finalSubmitBtn = document.getElementById('submitSignatureBtn');
                finalSubmitBtn.addEventListener('click', function() {
                    if (signaturePad && signaturePad.isEmpty()) {
                        alert("Vui lòng ký tên trước khi hoàn tất! (Please provide a signature)");
                        return;
                    }
                    
                    // Prevent double click
                    if (finalSubmitBtn.disabled) return;
                    finalSubmitBtn.disabled = true;
                    finalSubmitBtn.innerHTML = 'Đang xử lý...';
                    
                    sigInput.value = signaturePad.toDataURL();
                    form.submit();
                });

                // Initial check in case some fields are pre-filled
                checkAll();
            }
            
            // Prevent scrolling on body when modal is open
            document.body.style.overflow = 'hidden';
        });
    </script>
    <% } %>
</body>
</html>
