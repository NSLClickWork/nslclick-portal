<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'de' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="<%= appBaseUrl %>">
    <title>NSL Portal – Candidate Setcard</title>
    <link rel="icon" type="image/png" href="logo-shadow.png">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --nsl-red: #cc1f1f;
            --nsl-gold: #f2a900;
            --nsl-dark: #222;
            --nsl-light: #f8f9fa;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Montserrat', sans-serif;
        }

        body, html {
            /* Remove the weird checkered background, just use a clean soft gray like a real app */
            background-color: #f0f2f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--nsl-dark);
            overflow-x: hidden;
            width: 100%;
        }

        .container {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* Top Wavy Banner - Fixed to not stretch weirdly */
        .wavy-header {
            position: relative;
            height: 180px;
            width: 100%;
            overflow: hidden;
            z-index: 1;
        }
        
        .header-controls {
            position: absolute;
            top: 20px;
            right: 40px;
            z-index: 100;
            display: flex;
            gap: 20px;
            align-items: center;
        }
        
        .lang-switch {
            background: rgba(0,0,0,0.3);
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 14px;
        }

        .header-link {
            color: #fff;
            text-decoration: none;
            font-weight: 700;
            background: transparent;
            border: 2px solid #fff;
            padding: 6px 15px;
            border-radius: 5px;
            font-size: 14px;
            transition: 0.3s;
        }
        
        .header-link:hover { background: rgba(0,0,0,0.2); }



        /* Main Card Container */
        .card-inner {
            background: white;
            max-width: 1050px; /* Perfect width for 1 photo */
            margin: 40px auto 60px; /* No overlap with the wave */
            border-radius: 24px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            position: relative;
            z-index: 10;
            padding: 50px 60px;
            display: flex;
            flex-direction: column;
            min-height: 600px;
        }

        .card-photos-2 {
            max-width: 1250px; /* Expanded for 2 photos */
        }
        
        .card-photos-0 {
            max-width: 800px; /* Compact width for no photos */
        }

        .card-logo-box {
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .card-logo-box img {
            height: 80px;
        }
        .card-profession-title {
            font-size: 36px;
            font-weight: 900;
            color: var(--nsl-red);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Profile Content Layout */
        .profile-flex {
            display: flex;
            gap: 50px;
            align-items: flex-start;
        }

        /* 0 Photos Layout */
        .layout-photos-0 {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .layout-photos-0 .info-section {
            align-items: center;
            width: 100%;
        }
        .layout-photos-0 .info-grid {
            margin: 0 auto 30px;
        }

        /* 2 Photos Layout */
        .layout-photos-2 {
            gap: 40px; /* Better gap between photos and text */
        }
        .layout-photos-2 .superpowers-box {
            max-width: 100%;
        }

        /* Photos Section */
        .photos-wrapper {
            display: flex;
            gap: 15px;
        }

        .photo-box {
            width: 260px;
            height: 350px;
            border-radius: 20px;
            border: 4px solid var(--nsl-gold);
            overflow: hidden;
            background: #f8f9fa;
            flex-shrink: 0;
            box-shadow: 0 10px 25px rgba(242, 169, 0, 0.15);
        }

        .photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Information Section */
        .info-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .student-name {
            font-size: 38px;
            font-weight: 900;
            color: var(--nsl-gold);
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: auto auto 1fr;
            column-gap: 30px;
            row-gap: 16px;
            font-size: 19px;
            margin-bottom: 20px;
            width: fit-content;
        }

        .info-label { font-weight: 800; color: #111; text-align: left; }
        .info-sep { font-weight: 600; color: #555; }
        .info-value { font-weight: 500; color: #333; text-align: left; }

        /* Superpowers */
        .superpowers-box {
            background: var(--nsl-gold);
            border-radius: 20px;
            padding: 25px 35px;
            text-align: center;
            margin-top: 20px;
            box-shadow: 0 10px 20px rgba(242, 169, 0, 0.2);
            /* Align left to match Canva */
            width: 100%;
            max-width: 480px;
        }
        
        .sp-title {
            color: var(--nsl-red);
            font-weight: 900;
            font-size: 20px;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sp-list p {
            font-weight: 800;
            font-size: 16px;
            color: #111;
            line-height: 1.8;
            text-align: left;
        }

        /* Footer Text */
        .disclaimer-text {
            text-align: center;
            font-size: 13px;
            font-weight: 500;
            color: #666;
            margin-top: 40px;
            padding: 0 60px;
            line-height: 1.5;
        }

        /* Video Button */
        .video-action {
            text-align: center;
            margin-top: 40px;
            margin-bottom: 10px;
        }

        .video-btn {
            display: inline-block;
            background: var(--nsl-red);
            color: white;
            text-decoration: underline;
            text-underline-offset: 4px;
            padding: 18px 45px;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 800;
            box-shadow: 0 10px 25px rgba(204, 31, 31, 0.35);
            transition: transform 0.2s, background 0.2s;
        }

        .video-btn:hover {
            background: #a11616;
            transform: translateY(-3px);
        }

        /* Bottom Wave */
        .wavy-footer {
            height: 80px;
            margin-top: auto;
            position: relative;
            overflow: hidden;
        }

        @media (max-width: 900px) {
            .wavy-header { height: 120px; }
            .header-controls {
                right: 15px;
                top: 15px;
                gap: 10px;
            }
            .lang-switch {
                padding: 6px 10px;
                font-size: 12px;
            }
            .header-link {
                padding: 5px 10px;
                font-size: 12px;
            }
            .card-inner { margin: 20px 15px 30px; padding: 30px 20px; }
            .profile-flex { flex-direction: column; align-items: center; gap: 30px; }
            .photos-wrapper { flex-wrap: wrap; justify-content: center; }
            .photo-box { width: 200px; height: 266px; }
            .student-name { font-size: 28px; text-align: center; margin-bottom: 20px; }
            
            /* Fix Grid Overflow on Mobile */
            .info-grid { 
                font-size: 15px; 
                column-gap: 10px; 
                width: 100%; 
                max-width: 100%;
                overflow-wrap: break-word;
                word-wrap: break-word;
            }
            .info-label { max-width: 140px; }
            
            .card-logo-box { flex-direction: column; gap: 15px; margin-bottom: 20px; }
            .card-logo-box img { height: 60px; }
            .card-profession-title { font-size: 20px; text-align: center; }
            .superpowers-box { max-width: 100%; padding: 20px; }
            
            .video-action { margin-top: 25px; margin-bottom: 15px; }
            .video-btn { padding: 14px 24px; font-size: 16px; width: 90%; max-width: 300px; display: inline-block; white-space: normal; line-height: 1.3; }
            .disclaimer-text { font-size: 11px; margin-top: 20px; padding: 0; width: 100%; line-height: 1.4; color: #777; }
        }

        /* Progress Bar */
        .progress-container {
            margin-top: 40px;
            width: 100%;
        }
        .progress-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--nsl-red);
            text-transform: uppercase;
            margin-bottom: 25px;
            text-align: center;
        }
        .stepper {
            display: flex;
            justify-content: space-between;
            position: relative;
            width: 100%;
        }
        .stepper::before {
            content: '';
            position: absolute;
            top: 15px;
            left: 0;
            right: 0;
            height: 4px;
            background: #e0e0e0;
            z-index: 1;
        }
        .stepper-progress {
            position: absolute;
            top: 15px;
            left: 0;
            height: 4px;
            background: var(--nsl-gold);
            z-index: 2;
            transition: width 0.5s ease;
        }
        .step {
            position: relative;
            z-index: 3;
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 16.66%;
        }
        .step-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #e0e0e0;
            border: 4px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 14px;
            color: #666;
            transition: 0.3s;
        }
        .step.active .step-circle {
            background: var(--nsl-gold);
            color: #fff;
            border-color: #fff;
            box-shadow: 0 0 0 4px rgba(242, 169, 0, 0.3);
        }
        .step.completed .step-circle {
            background: var(--nsl-gold);
            color: #fff;
            border-color: #fff;
        }
        .step-label {
            margin-top: 10px;
            font-size: 12px;
            font-weight: 700;
            color: #777;
            text-align: center;
            line-height: 1.3;
        }
        .step.active .step-label {
            color: var(--nsl-dark);
        }
        @media (max-width: 900px) {
            .progress-container { margin-top: 30px; }
            .step-label { font-size: 10px; }
            .step-circle { width: 28px; height: 28px; font-size: 12px; border-width: 3px; }
            .stepper::before, .stepper-progress { top: 12px; }
        }
    </style>
</head>
<body>
    <% 
        // Helper to format missing or zero values as "Ausstehend"
        function formatValue(val) {
            if (val === undefined || val === null || val === '' || val === '0' || val === 0 || val === '—' || val === 'Pending') {
                return 'Ausstehend';
            }
            return val;
        }

        // Helper calculations
        // Extract birth year from Student ID (e.g., ANG_Huyen_NGUYEN_03.10.2006 -> 2006)
        let birthYear = 'N/A';
        const yearMatch = student.StudentID ? student.StudentID.match(/\d{4}$/) : null;
        if (yearMatch) birthYear = yearMatch[0];

        // Determine Level and Score from the actual data
        let actualScore = student.NSLScore || '0'; 
        let actualLevel = student.NSLGrade || '—';
        
        // Availability
        let actualAvailability = student.AvailableFrom;
        if (!actualAvailability || actualAvailability.trim() === '') {
            actualAvailability = '—';
        }
        
        let rawVideo = student['Introduction Video'] || student.YouTubeLink || student.DriveVideoLink || '';
        // It has a video if the field is not empty, not 'FALSE', and looks like a URL (longer than 5 chars)
        let hasVideo = rawVideo && rawVideo.trim().length > 5 && rawVideo.toUpperCase() !== 'FALSE';
        let videoLink = hasVideo ? rawVideo.trim() : '#';
    %>

    <div class="container">
        <!-- Top Banner Waves -->
        <div class="wavy-header">
        <div class="header-controls">
            <div class="lang-switch" style="background: rgba(0,0,0,0.3); padding: 8px 15px; border-radius: 20px;">
                <a href="javascript:void(0)" onclick="window.location.search='?lang=de&_cb=<%= Date.now() %>'" style="color: #fff; text-decoration: none; font-weight: <%= typeof lang !== 'undefined' && lang === 'de' ? '900' : '500' %>; opacity: <%= typeof lang !== 'undefined' && lang === 'de' ? '1' : '0.6' %>;">DE</a> <span style="color:#fff;opacity:0.5">|</span>
                <a href="javascript:void(0)" onclick="window.location.search='?lang=en&_cb=<%= Date.now() %>'" style="color: #fff; text-decoration: none; font-weight: <%= typeof lang !== 'undefined' && lang === 'en' ? '900' : '500' %>; opacity: <%= typeof lang !== 'undefined' && lang === 'en' ? '1' : '0.6' %>;">EN</a> <span style="color:#fff;opacity:0.5">|</span>
                <a href="javascript:void(0)" onclick="window.location.search='?lang=vi&_cb=<%= Date.now() %>'" style="color: #fff; text-decoration: none; font-weight: <%= typeof lang !== 'undefined' && lang === 'vi' ? '900' : '500' %>; opacity: <%= typeof lang !== 'undefined' && lang === 'vi' ? '1' : '0.6' %>;">VI</a>
            </div>
            <% if (typeof partner !== 'undefined' && partner) { %>
                <a href="partner/dashboard" class="header-link">Back</a>
            <% } else { %>
                <a href="login" class="header-link"><%= __('logout') %></a>
            <% } %>
        </div>
            <svg viewBox="0 0 1000 140" preserveAspectRatio="none" style="width:100%; height:100%;">
                <!-- Yellow wave (thick on left) -->
                <path d="M0,0 L1000,0 L1000,80 Q500,140 0,140 Z" fill="#f2a900" />
                <!-- Red wave (thick on right) -->
                <path d="M0,0 L1000,0 L1000,140 Q600,140 200,0 Z" fill="#cc1f1f" />
            </svg>
        </div>

        <% 
            let photoCount = 0;
            if (student.PhotoLink && student.PhotoLink.trim() !== '') photoCount++;
            if (student.ActivityPhotoLink && student.ActivityPhotoLink.trim() !== '') photoCount++;
        %>
        <div class="card-inner card-photos-<%= photoCount %>">
            <div class="card-logo-box">
                <img src="logo-shadow.png" alt="NSL">
                <div class="card-profession-title">BERUFE - <%= (student['Nghề nghiệp'] || student.Profession || student.ProfessionCode || 'FACHVERKÄUFERIN').toUpperCase() %></div>
            </div>

            <div class="profile-flex layout-photos-<%= photoCount %>">
                <!-- Photos Section -->
                <div class="photos-wrapper">
                    <!-- Portrait Photo Frame -->
                    <% if (student.PhotoLink && student.PhotoLink.trim() !== '') { %>
                    <div class="photo-box">
                        <img src="photos/<%= encodeURIComponent(student.FullName) %>.jpg" onerror="this.onerror=null; this.src='proxy/students/<%= student.StudentID %>/photo'; this.addEventListener('error', function(){this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%23f0f0f0\'/><text x=\'50%\' y=\'50%\' fill=\'%23999\' font-family=\'sans-serif\' font-size=\'14\' text-anchor=\'middle\' dominant-baseline=\'middle\'>No Photo</text></svg>'});" alt="Portrait">
                    </div>
                    <% } %>
                    
                    <!-- Activity Photo Frame (Only shows if there is a link) -->
                    <% if (student.ActivityPhotoLink && student.ActivityPhotoLink.trim() !== '') { %>
                    <div class="photo-box">
                        <img src="proxy/students/<%= student.StudentID %>/activity-photo" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'100%\' height=\'100%\'><rect width=\'100%\' height=\'100%\' fill=\'%23e0e0e0\'/><text x=\'50%\' y=\'50%\' fill=\'%23888\' font-family=\'sans-serif\' font-size=\'14\' text-anchor=\'middle\' dominant-baseline=\'middle\'>Activity Photo</text></svg>'" alt="Activity">
                    </div>
                    <% } %>
                </div>

                <!-- Info Section -->
                <div class="info-section">
                    <h2 class="student-name"><%= student['Short Name'] || student.FullName %></h2>
                    
                    <div class="info-grid">
                        <div class="info-label"><%= __('birth_year') %></div><div class="info-sep">:</div><div class="info-value"><%= birthYear %></div>
                        <div class="info-label"><%= __('deutsch_level') %></div><div class="info-sep">:</div><div class="info-value"><%= formatValue(student.DeutschLevel) %></div>
                        <div class="info-label"><%= __('nsl_result') %></div><div class="info-sep">:</div><div class="info-value"><%= formatValue(actualScore) %></div>
                        <div class="info-label"><%= __('integration_level') %></div><div class="info-sep">:</div><div class="info-value"><%= formatValue(student.Rank) %></div>
                        <div class="info-label"><%= __('availability') %></div><div class="info-sep">:</div><div class="info-value"><%= actualAvailability %></div>
                    </div>

                    <% 
                        let sp1 = student.Strength1 || student['Superpower 1'] || student['Strength 1'] || '';
                        let sp2 = student.Strength2 || student['Superpower 2'] || student['Strength 2'] || '';
                        let sp3 = student.Strength3 || student['Superpower 3'] || student['Strength 3'] || '';
                    %>
                    <% if (sp1 || sp2 || sp3) { %>
                    <!-- Superpowers -->
                    <div class="superpowers-box">
                        <div class="sp-title"><%= __('superpowers') %></div>
                        <div class="sp-list">
                            <% if (sp1) { %><p>1. <%= sp1 %></p><% } %>
                            <% if (sp2) { %><p>2. <%= sp2 %></p><% } %>
                            <% if (sp3) { %><p>3. <%= sp3 %></p><% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <% 
                let currentStep = parseInt(student.ProgressStatus) || 1;
                if (currentStep < 1) currentStep = 1;
                if (currentStep > 6) currentStep = 6;
                let progressPercent = ((currentStep - 1) / 5) * 100;
                
                const steps = [
                    __('prog_1'),
                    __('prog_2'),
                    __('prog_3'),
                    __('prog_4'),
                    __('prog_5'),
                    __('prog_6')
                ];
            %>
            <div class="progress-container">
                <div class="progress-title"><%= __('prog_title') %></div>
                <div class="stepper">
                    <div class="stepper-progress" style="width: <%= progressPercent %>%;"></div>
                    <% for(let i=1; i<=6; i++) { %>
                        <div class="step <%= currentStep === i ? 'active' : '' %> <%= currentStep > i ? 'completed' : '' %>">
                            <div class="step-circle"><%= i %></div>
                            <div class="step-label"><%- steps[i-1] %></div>
                        </div>
                    <% } %>
                </div>
            </div>

            <% if (hasVideo) { %>
            <div class="video-action">
                <a href="<%= videoLink %>" target="_blank" class="video-btn">
                    <%= __('view_video') %>
                </a>
            </div>
            <% } %>

            <!-- ONBOARDING CTA FOR CANDIDATES -->
            <div style="text-align: center; margin-top: 30px; margin-bottom: 20px;">
                <p style="font-size: 14px; font-weight: 600; color: var(--nsl-red); margin-bottom: 15px; text-transform: uppercase;">
                    Ready for the next step?
                </p>
                <a href="https://outlook.office365.com/owa/calendar/CANDIDATE_BOOKING_LINK" target="_blank" class="btn-nsl-brutal" style="display: inline-block; padding: 15px 30px; border-radius: 50px; background: var(--text-main); color: #fff; border: 2px solid var(--text-main); text-decoration: none;">
                    📅 Book Onboarding Session
                </a>
            </div>

            <p class="disclaimer-text">
                <%= __('disclaimer') %>
            </p>

        </div>

        <!-- Bottom Wave -->
        <div class="wavy-footer">
            <svg viewBox="0 0 1000 60" preserveAspectRatio="none" style="width:100%; height:100%;">
                <path d="M0,20 Q500,70 1000,20 L1000,60 L0,60 Z" fill="#1a1a1a" />
            </svg>
        </div>
    </div>
    <%- include('./partials/chat_widget') %>
</body>
</html>
