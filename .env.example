# Server Config
PORT=3000
NODE_ENV=development

# Security
SESSION_SECRET=your_super_secret_session_key_here
CSRF_SECRET=12345678901234567890123456789012 # Must be 32 characters

# Admin
ADMIN_PASSWORD=fallback_plaintext_password_for_dev
ADMIN_PASSWORD_HASH=$2b$10$w... # bcrypt hash of your admin password (recommended)

# Google Sheets/Drive Config
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# Note: Place credentials.json (Service Account) in the root directory

# YouTube OAuth Config
GOOGLE_CLIENT_ID=your_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
# Note: Run the oauth flow to generate token.json in the root directory
